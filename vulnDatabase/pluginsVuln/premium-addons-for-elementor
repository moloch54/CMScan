v":"network","ac":"low","pr":"low","ui":"required","s":"changed","c":"low","i":"low","a":"none","exploitable":"2.3","impact":"2.7"},"cwe":[{"cwe":"CWE-79","name":"Improper Neutralization of Input During Web Page Generation ('Cross-site Scripting')","description":"The product does not neutralize or incorrectly neutralizes user-controllable input before it is placed in output that is used as a web page that is served to other users."}]}},{"uuid":"c330749032703dd4983a7e297fb764f90d0519d981671d8de4e5e96ccc36d557","name":"Premium Addons for Elementor &#8211; Powerful Elementor Templates &amp; Widgets [premium-addons-for-elementor] < 4.5.2","description":null,"operator":{"min_version":null,"min_operator":null,"max_version":"4.5.2","max_operator":"lt","unfixed":"0","closed":"0"},"source":[{"id":"ca16f455a299d73438614682ed8715575c30571f","name":"WordPress Premium Addons for Elementor plugin <= 4.5.1 - Arbitrary Blog Option Update vulnerability","link":"https:\/\/patchstack.com\/database\/wordpress\/plugin\/premium-addons-for-elementor\/vulnerability\/wordpress-premium-addons-for-elementor-plugin-4-5-1-arbitrary-blog-option-update-vulnerability","description":"Arbitrary Blog Option Update vulnerability discovered by WPScanTeam in WordPress Premium Addons for Elementor plugin (versions <= 4.5.1).","date":"2021-08-30"}],"impact":[]},{"uuid":"88f7e0ebbcbe14a9109904c267ebe46a6eb67934195ddd1936034acc463abebf","name":"Premium Addons for Elementor &#8211; Powerful Elementor Templates &amp; Widgets [premium-addons-for-elementor] < 4.2.8","description":null,"operator":{"min_version":null,"min_operator":null,"max_version":"4.2.8","max_operator":"lt","unfixed":"0","closed":"0"},"source":[{"id":"2c9744e15cf587028ca5c0a1d1465a9612e0c5ea","name":"WordPress Premium Addons for Elementor plugin <= 4.2.7 - Multiple Authenticated Stored Cross-Site Scripting (XSS) vulnerabilities","link":"https:\/\/patchstack.com\/database\/wordpress\/plugin\/premium-addons-for-elementor\/vulnerability\/wordpre