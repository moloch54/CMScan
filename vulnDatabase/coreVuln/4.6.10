L\/PR:N\/UI:R\/S:C\/C:L\/I:L\/A:N","av":"n","ac":"l","pr":"n","ui":"r","s":"c","c":"l","i":"l","a":"n","score":"6.1","severity":"m","exploitable":"2.8","impact":"2.7"},"cvss3":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:N\/UI:R\/S:C\/C:L\/I:L\/A:N","score":"6.1","severity":"medium","av":"network","ac":"low","pr":"none","ui":"required","s":"changed","c":"low","i":"low","a":"none","exploitable":"2.8","impact":"2.7"},"cwe":[{"cwe":"CWE-79","name":"Improper Neutralization of Input During Web Page Generation ('Cross-site Scripting')","description":"The product does not neutralize or incorrectly neutralizes user-controllable input before it is placed in output that is used as a web page that is served to other users."}]}},{"uuid":"81eae1bc3f7ed279590ec75e79649bc4fed5f466c72c3ae79a13e3e6410db748","name":"4.6.10","description":null,"source":[{"id":"46f068f483118a5c7b25c25253dad32d54476d79","name":"WordPress Core < 5.2.3 - Stored Cross-Site Scripting via Comments via URLs","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-523-stored-cross-site-scripting-via-comments-via-urls","description":"WordPress before 5.2.3 has an issue with URL sanitization in wp_kses_bad_protocol_once in wp-includes\/kses.php that can lead to cross-site scripting (XSS) attacks.","date":"2019-09-05"}],"impact":[]},{"uuid":"315040659e51519908bb0fcb2640d44e563403e1e0aa33ac3d5ba832b0b44511","name":"4.6.10","description":null,"source":[{"id":"CVE-2019-16223","name":"CVE-2019-16223","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2019-16223","description":"[en] WordPress before 5.2.3 allows XSS in post previews by authenticated users.","date":"2019-09-11"}],"impact":{"cvss":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:L\/UI:R\/S:C\/C:L\/I:L\/A:N","av":"n","ac":"l","pr":"l","ui":"r","s":"c","c":"l","i":"l","a":"n","score":"5.4","severity":"m","exploitable":"2.3","impact":"2.7"},"cvss3":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:L\/UI:R\/S:C\/C:L\/I:L\/A:N","score":"5.4","severity":"medium","av":"network","ac":"low","pr":"low","ui":"required","s":"changed","c":"low","i":"low","a":"none","exploitable":"2.3","impact":"2.7"},"cwe":[{"cwe":"CWE-79","name":"Improper Neutralization of Input During Web Page Generation ('Cross-site Scripting')","description":"The product does not neutralize or incorrectly neutralizes user-controllable input before it is placed in output that is used as a web page that is served to other users."}]}},{"uuid":"315040659e51519908bb0fcb2640d44e563403e1e0aa33ac3d5ba832b0b44511","name":"4.6.10","description":null,"source":[{"id":"c2ca3944c7aefe53a54f238800ccf33f6db5f123","name":"WordPress Core < 5.2.3 - Authenticated Cross-Site Scripting via Post Previews","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-523-authenticated-cross-site-scripting-via-post-previews","description":"WordPress before 5.2.3 allows XSS in post previews by authenticated users.","date":"2019-09-05"}],"impact":[]},{"uuid":"ddd3c474d278a9197cc9f2825269d16aa962c127b64471d73c375cd039d5d132","name":"4.6.10","description":null,"source":[{"id":"CVE-2019-9787","name":"CVE-2019-9787","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2019-9787","description":"[en] WordPress before 5.1.1 does not properly filter comment content, leading to Remote Code Execution by unauthenticated users in a default configuration. This occurs because CSRF protection is mishandled, and because Search Engine Optimization of A elements is performed incorrectly, leading to XSS. The XSS results in administrative access, which allows arbitrary changes to .php files. This is related to wp-admin\/includes\/ajax-actions.php and wp-includes\/comment.php.","date":"2019-03-14"}],"impact":{"cvss":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:L\/PR:N\/UI:R\/S:U\/C:H\/I:H\/A:H","av":"n","ac":"l","pr":"n","ui":"r","s":"u","c":"h","i":"h","a":"h","score":"8.8","severity":"h","exploitable":"2.8","impact":"5.9"},"cvss3":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:L\/PR:N\/UI:R\/S:U\/C:H\/I:H\/A:H","score":"8.8","severity":"high","av":"network","ac":"low","pr":"none","ui":"required","s":"unchanged","c":"high","i":"high","a":"high","exploitable":"2.8","impact":"5.9"},"cwe":[{"cwe":"CWE-352","name":"Cross-Site Request Forgery (CSRF)","description":"The web application does not, or cannot, sufficiently verify whether a request was intentionally provided by the user who sent the request, which could have originated from an unauthorized actor."}]}},{"uuid":"ddd3c474d278a9197cc9f2825269d16aa962c127b64471d73c375cd039d5d132","name":"4.6.10","description":null,"source":[{"id":"49b498cb6fc40d215196463cc4fb1a435285f885","name":"WordPress Core < 5.1.1 - Cross-Site Request Forgery to Cross-Site Scripting via Comments","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-511-cross-site-request-forgery-to-cross-site-scripting-via-comments","description":"WordPress before 5.1.1 does not properly filter comment content, leading to Remote Code Execution by unauthenticated users in a default configuration. This occurs because CSRF protection is mishandled, and because Search Engine Optimization of A elements is performed incorrectly, leading to XSS. The XSS results in administrative access, which allows arbitrary changes to .php files. This is related to wp-admin\/includes\/ajax-actions.php and wp-includes\/comment.php.","date":"2019-04-12"}],"impact":[]},{"uuid":"0972029bd0371e2eae8f7eeb29434c52a5a5f02f58019471ec93f2fdd19f124f","name":"4.6.10","description":null,"source":[{"id":"CVE-2019-8942","name":"CVE-2019-8942","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2019-8942","description":"[en] WordPress before 4.9.9 and 5.x before 5.0.1 allows remote code execution because an _wp_attached_file Post Meta entry can be changed to an arbitrary string, such as one ending with a .jpg?file.php substring. An attacker with author privileges can execute arbitrary code by uploading a crafted image containing PHP code in the Exif metadata. Exploitation can leverage CVE-2019-8943.","date":"2019-02-20"}],"impact":{"cvss":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:L\/PR:L\/UI:N\/S:U\/C:H\/I:H\/A:H","av":"n","ac":"l","pr":"l","ui":"n","s":"u","c":"h","i":"h","a":"h","score":"8.8","severity":"h","exploitable":"2.8","impact":"5.9"},"cvss3":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:L\/PR:L\/UI:N\/S:U\/C:H\/I:H\/A:H","score":"8.8","severity":"high","av":"network","ac":"low","pr":"low","ui":"none","s":"unchanged","c":"high","i":"high","a":"high","exploitable":"2.8","impact":"5.9"},"cwe":[{"cwe":"CWE-434","name":"Unrestricted Upload of File with Dangerous Type","description":"The product allows the upload or transfer of dangerous file types that are automatically processed within its environment."}]}},{"uuid":"0972029bd0371e2eae8f7eeb29434c52a5a5f02f58019471ec93f2fdd19f124f","name":"4.6.10","description":null,"source":[{"id":"b8867b6c1bb35517dc4f9d59ba407a1e1e3d6808","name":"WordPress 3.7-5.0 (except 4.9.9) - Authenticated Code Execution vulnerability","link":"https:\/\/patchstack.com\/database\/wordpress\/wordpress\/wordpress\/vulnerability\/wordpress-3-7-5-0-except-4-9-9-authenticated-code-execution-vulnerability","description":"Authenticated Code Execution vulnerability found by Simon Scannell (RIPS Technologies) in WordPress (versions 3.7-5.0, except 4.9.9).","date":"2019-02-28"}],"impact":[]},{"uuid":"0972029bd0371e2eae8f7eeb29434c52a5a5f02f58019471ec93f2fdd19f124f","name":"4.6.10","description":null,"source":[{"id":"ede74e56ccbed25ad3aa1f66e542628688ae6825","name":"WordPress Core < 5.0.1 - Remote Code Execution","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-501-remote-code-execution","description":"WordPress before 4.9.9 and 5.x before 5.0.1 allows remote code execution because an _wp_attached_file Post Meta entry can be changed to an arbitrary string, such as one ending with a .jpg?file.php substring. An attacker with author privileges can execute arbitrary code by uploading a crafted image containing PHP code in the Exif metadata. Exploitation can leverage CVE-2019-8943.","date":"2019-02-19"}],"impact":[]},{"uuid":"c19f9c9dad1c4c39c49ae51b78c7cd446b545deace2004b3389c7aa319568a4d","name":"4.6.10","description":null,"source":[{"id":"CVE-2019-8943","name":"CVE-2019-8943","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2019-8943","description":"[en] WordPress through 5.0.3 allows Path Traversal in wp_crop_image(). An attacker (who has privileges to crop an image) can write the output image to an arbitrary directory via a filename containing two image extensions and ..\/ sequences, such as a filename ending with the .jpg?\/..\/..\/file.jpg substring.","date":"2019-02-20"}],"impact":{"cvss":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:L\/UI:N\/S:U\/C:N\/I:H\/A:N","av":"n","ac":"l","pr":"l","ui":"n","s":"u","c":"n","i":"h","a":"n","score":"6.5","severity":"m","exploitable":"2.8","impact":"3.6"},"cvss3":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:L\/UI:N\/S:U\/C:N\/I:H\/A:N","score":"6.5","severity":"medium","av":"network","ac":"low","pr":"low","ui":"none","s":"unchanged","c":"none","i":"high","a":"none","exploitable":"2.8","impact":"3.6"},"cwe":[{"cwe":"CWE-22","name":"Improper Limitation of a Pathname to a Restricted Directory ('Path Traversal')","description":"The product uses external input to construct a pathname that is intended to identify a file or directory that is located underneath a restricted parent directory, but the product does not properly neutralize special elements within the pathname that can cause the pathname to resolve to a location that is outside of the restricted directory."}]}},{"uuid":"c19f9c9dad1c4c39c49ae51b78c7cd446b545deace2004b3389c7aa319568a4d","name":"4.6.10","description":null,"source":[{"id":"2503934a5f1db74cfe72e5872302acfc7ed08b36","name":"WordPress Core <= 5.0.3 - Path Traversal and Local File Inclusion","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-503-path-traversal-and-local-file-inclusion","description":"WordPress through 5.0.3 allows Path Traversal in wp_crop_image(). An attacker (who has privileges to crop an image) can write the output image to an arbitrary directory via a filename containing two image extensions and ..\/ sequences, such as a filename ending with the .jpg?\/..\/..\/file.jpg substring.","date":"2019-02-19"}],"impact":[]},{"uuid":"d156923558be7f4b198622505e8af1baa2f051635ce52b7cab940dc6df38c6c0","name":"4.6.10","description":null,"source":[{"id":"CVE-2018-20147","name":"CVE-2018-20147","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2018-20147","description":"[en] In WordPress before 4.9.9 and 5.x before 5.0.1, authors could modify metadata to bypass intended restrictions on deleting files.","date":"2018-12-14"}],"impact":{"cvss":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:L\/PR:L\/UI:N\/S:U\/C:N\/I:H\/A:N","av":"n","ac":"l","pr":"l","ui":"n","s":"u","c":"n","i":"h","a":"n","score":"6.5","severity":"m","exploitable":"2.8","impact":"3.6"},"cvss3":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:L\/PR:L\/UI:N\/S:U\/C:N\/I:H\/A:N","score":"6.5","severity":"medium","av":"network","ac":"low","pr":"low","ui":"none","s":"unchanged","c":"none","i":"high","a":"none","exploitable":"2.8","impact":"3.6"},"cwe":[{"cwe":"CWE-863","name":"Incorrect Authorization","description":"The product performs an authorization check when an actor attempts to access a resource or perform an action, but it does not correctly perform the check."}]}},{"uuid":"d156923558be7f4b198622505e8af1baa2f051635ce52b7cab940dc6df38c6c0","name":"4.6.10","description":null,"source":[{"id":"09b0e0da731cdc68ce0b6f397f84e86e979135ed","name":"WordPress Core < 5.0.1 -  Arbitrary File Deletion","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-501-arbitrary-file-deletion","description":"In WordPress before 4.9.9 and 5.x before 5.0.1, authors could modify metadata to bypass intended restrictions on deleting files.","date":"2018-12-12"}],"impact":[]},{"uuid":"f6bbe64e03191e2c8b2321ed671ed84facdf10cc17fd58b1908c2e6b6993ee00","name":"4.6.10","description":null,"source":[{"id":"CVE-2018-20151","name":"CVE-2018-20151","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2018-20151","description":"[en] In WordPress before 4.9.9 and 5.x before 5.0.1, the user-activation page could be read by a search engine's web crawler if an unusual configuration were chosen. The search engine could then index and display a user's e-mail address and (rarely) the password that was generated by default.","date":"2018-12-14"}],"impact":{"cvss":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:L\/PR:N\/UI:N\/S:U\/C:H\/I:N\/A:N","av":"n","ac":"l","pr":"n","ui":"n","s":"u","c":"h","i":"n","a":"n","score":"7.5","severity":"h","exploitable":"3.9","impact":"3.6"},"cvss3":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:L\/PR:N\/UI:N\/S:U\/C:H\/I:N\/A:N","score":"7.5","severity":"high","av":"network","ac":"low","pr":"none","ui":"none","s":"unchanged","c":"high","i":"none","a":"none","exploitable":"3.9","impact":"3.6"},"cwe":[{"cwe":"CWE-200","name":"Exposure of Sensitive Information to an Unauthorized Actor","description":"The product exposes sensitive information to an actor that is not explicitly authorized to have access to that information."}]}},{"uuid":"f6bbe64e03191e2c8b2321ed671ed84facdf10cc17fd58b1908c2e6b6993ee00","name":"4.6.10","description":null,"source":[{"id":"f6da7d65628fde71e3f5ac2ca80d953c31c5f8a5","name":"WordPress Core < 5.0.1 - Sensitive Information Disclosure","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-501-sensitive-information-disclosure","description":"In WordPress before 4.9.9 and 5.x before 5.0.1, the user-activation page could be read by a search engine's web crawler if an unusual configuration were chosen. The search engine could then index and display a user's e-mail address and (rarely) the password that was generated by default.","date":"2018-12-12"}],"impact":[]},{"uuid":"d2943fe4f7ede662cf53f2cbea6c831826f960d5a97009475cb212d950729fe2","name":"4.6.10","description":null,"source":[{"id":"CVE-2018-20152","name":"CVE-2018-20152","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2018-20152","description":"[en] In WordPress before 4.9.9 and 5.x before 5.0.1, authors could bypass intended restrictions on post types via crafted input.","date":"2018-12-14"}],"impact":{"cvss":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:L\/PR:L\/UI:N\/S:U\/C:N\/I:H\/A:N","av":"n","ac":"l","pr":"l","ui":"n","s":"u","c":"n","i":"h","a":"n","score":"6.5","severity":"m","exploitable":"2.8","impact":"3.6"},"cvss3":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:L\/PR:L\/UI:N\/S:U\/C:N\/I:H\/A:N","score":"6.5","severity":"medium","av":"network","ac":"low","pr":"low","ui":"none","s":"unchanged","c":"none","i":"high","a":"none","exploitable":"2.8","impact":"3.6"},"cwe":[{"cwe":"CWE-20","name":"Improper Input Validation","description":"The product receives input or data, but it does\n        not validate or incorrectly validates that the input has the\n        properties that are required to process the data safely and\n        correctly."}]}},{"uuid":"d2943fe4f7ede662cf53f2cbea6c831826f960d5a97009475cb212d950729fe2","name":"4.6.10","description":null,"source":[{"id":"cba22c82f551eef7835b814a2d235196a4162efc","name":"WordPress Core < 5.0.1 - Authorization Bypass","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-501-authorization-bypass","description":"In WordPress before 4.9.9 and 5.x before 5.0.1, authors could bypass intended restrictions on post types via crafted input.","date":"2018-12-12"}],"impact":[]},{"uuid":"d15f16d9acd2baad59b38b1c3ddef8f784995a713cbcf30fbb713938cafe53dd","name":"4.6.10","description":null,"source":[{"id":"CVE-2018-20153","name":"CVE-2018-20153","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2018-20153","description":"[en] In WordPress before 4.9.9 and 5.x before 5.0.1, contributors could modify new comments made by users with greater privileges, possibly causing XSS.","date":"2018-12-14"}],"impact":{"cvss":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:L\/PR:L\/UI:R\/S:C\/C:L\/I:L\/A:N","av":"n","ac":"l","pr":"l","ui":"r","s":"c","c":"l","i":"l","a":"n","score":"5.4","severity":"m","exploitable":"2.3","impact":"2.7"},"cvss3":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:L\/PR:L\/UI:R\/S:C\/C:L\/I:L\/A:N","score":"5.4","severity":"medium","av":"network","ac":"low","pr":"low","ui":"required","s":"changed","c":"low","i":"low","a":"none","exploitable":"2.3","impact":"2.7"},"cwe":[{"cwe":"CWE-79","name":"Improper Neutralization of Input During Web Page Generation ('Cross-site Scripting')","description":"The product does not neutralize or incorrectly neutralizes user-controllable input before it is placed in output that is used as a web page that is served to other users."}]}},{"uuid":"d15f16d9acd2baad59b38b1c3ddef8f784995a713cbcf30fbb713938cafe53dd","name":"4.6.10","description":null,"source":[{"id":"144a19a69f8026dc69280bc92e3d36a8de1957fd","name":"WordPress Core < 5.0.1 - Authenticated Stored Cross-Site Scripting via Comments","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-501-authenticated-stored-cross-site-scripting-via-comments","description":"In WordPress before 4.9.9 and 5.x before 5.0.1, contributors could modify new comments made by users with greater privileges, possibly causing XSS.","date":"2018-12-12"}],"impact":[]},{"uuid":"6e0a2db37a14cde2fa63560d9e266708e20647e0da44f935cf4b9cfa886e116b","name":"4.6.10","description":null,"source":[{"id":"CVE-2018-20148","name":"CVE-2018-20148","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2018-20148","description":"[en] In WordPress before 4.9.9 and 5.x before 5.0.1, contributors could conduct PHP object injection attacks via crafted metadata in a wp.getMediaItem XMLRPC call. This is caused by mishandling of serialized data at phar:\/\/ URLs in the wp_get_attachment_thumb_file function in wp-includes\/post.php.","date":"2018-12-14"}],"impact":{"cvss":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:L\/PR:N\/UI:N\/S:U\/C:H\/I:H\/A:H","av":"n","ac":"l","pr":"n","ui":"n","s":"u","c":"h","i":"h","a":"h","score":"9.8","severity":"c","exploitable":"3.9","impact":"5.9"},"cvss3":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:L\/PR:N\/UI:N\/S:U\/C:H\/I:H\/A:H","score":"9.8","severity":"critical","av":"network","ac":"low","pr":"none","ui":"none","s":"unchanged","c":"high","i":"high","a":"high","exploitable":"3.9","impact":"5.9"},"cwe":[{"cwe":"CWE-502","name":"Deserialization of Untrusted Data","description":"The product deserializes untrusted data without sufficiently ensuring that the resulting data will be valid."}]}},{"uuid":"6e0a2db37a14cde2fa63560d9e266708e20647e0da44f935cf4b9cfa886e116b","name":"4.6.10","description":null,"source":[{"id":"8bba81778a63ec59bb48f2cb7e49200e0864ac64","name":"WordPress Core < 5.0.1 - PHP Object Injection","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-501-php-object-injection","description":"In WordPress before 4.9.9 and 5.x before 5.0.1, contributors could conduct PHP object injection attacks via crafted metadata in a wp.getMediaItem XMLRPC call. This is caused by mishandling of serialized data at phar:\/\/ URLs in the wp_get_attachment_thumb_file function in wp-includes\/post.php.","date":"2018-12-12"}],"impact":[]},{"uuid":"d6af4f59d48c0c9d8391fe0a222db79e31fd0cb67eabdd6fc4d07c25f05194ad","name":"4.6.10","description":null,"source":[{"id":"CVE-2018-20149","name":"CVE-2018-20149","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2018-20149","description":"[en] In WordPress before 4.9.9 and 5.x before 5.0.1, when the Apache HTTP Server is used, authors could upload crafted files that bypass intended MIME type restrictions, leading to XSS, as demonstrated by a .jpg file without JPEG data.","date":"2018-12-14"}],"impact":{"cvss":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:L\/PR:L\/UI:R\/S:C\/C:L\/I:L\/A:N","av":"n","ac":"l","pr":"l","ui":"r","s":"c","c":"l","i":"l","a":"n","score":"5.4","severity":"m","exploitable":"2.3","impact":"2.7"},"cvss3":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:L\/PR:L\/UI:R\/S:C\/C:L\/I:L\/A:N","score":"5.4","severity":"medium","av":"network","ac":"low","pr":"low","ui":"required","s":"changed","c":"low","i":"low","a":"none","exploitable":"2.3","impact":"2.7"},"cwe":[{"cwe":"CWE-79","name":"Improper Neutralization of Input During Web Page Generation ('Cross-site Scripting')","description":"The product does not neutralize or incorrectly neutralizes user-controllable input before it is placed in output that is used as a web page that is served to other users."}]}},{"uuid":"d6af4f59d48c0c9d8391fe0a222db79e31fd0cb67eabdd6fc4d07c25f05194ad","name":"4.6.10","description":null,"source":[{"id":"a54f1e9d2dceae8203d1b6c99f2c27d610a8b981","name":"WordPress Core < 5.0.1 - Stored Cross-Site Scripting via File Uploads","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-501-stored-cross-site-scripting-via-file-uploads","description":"In WordPress before 4.9.9 and 5.x before 5.0.1, when the Apache HTTP Server is used, authors could upload crafted files that bypass intended MIME type restrictions, leading to XSS, as demonstrated by a .jpg file without JPEG data.","date":"2018-12-12"}],"impact":[]},{"uuid":"08052385fc099cd6aa8419032ec7301cdad4994624e26b0679dd6f8de2d5bb24","name":"4.6.10","description":null,"source":[{"id":"CVE-2018-20150","name":"CVE-2018-20150","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2018-20150","description":"[en] In WordPress before 4.9.9 and 5.x before 5.0.1, crafted URLs could trigger XSS for certain use cases involving plugins.","date":"2018-12-14"}],"impact":{"cvss":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:L\/PR:N\/UI:R\/S:C\/C:L\/I:L\/A:N","av":"n","ac":"l","pr":"n","ui":"r","s":"c","c":"l","i":"l","a":"n","score":"6.1","severity":"m","exploitable":"2.8","impact":"2.7"},"cvss3":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:L\/PR:N\/UI:R\/S:C\/C:L\/I:L\/A:N","score":"6.1","severity":"medium","av":"network","ac":"low","pr":"none","ui":"required","s":"changed","c":"low","i":"low","a":"none","exploitable":"2.8","impact":"2.7"},"cwe":[{"cwe":"CWE-79","name":"Improper Neutralization of Input During Web Page Generation ('Cross-site Scripting')","description":"The product does not neutralize or incorrectly neutralizes user-controllable input before it is placed in output that is used as a web page that is served to other users."}]}},{"uuid":"08052385fc099cd6aa8419032ec7301cdad4994624e26b0679dd6f8de2d5bb24","name":"4.6.10","description":null,"source":[{"id":"7851c71be498597bfb37cc5756d42b48a094eaeb","name":"WordPress Core < 5.0.1 Reflected Cross-Site Scripting","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-501-reflected-cross-site-scripting","description":"In WordPress before 4.9.9 and 5.x before 5.0.1, crafted URLs could trigger XSS for certain use cases involving plugins.","date":"2018-12-12"}],"impact":[]},{"uuid":"bc19fe830c2aefc7a55481aaa2c71134da17f2365557da1c27824ed767799e74","name":"4.6.10","description":null,"source":[{"id":"CVE-2017-1000600","name":"CVE-2017-1000600","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2017-1000600","description":"[en] WordPress version <4.9 contains a CWE-20 Input Validation vulnerability in thumbnail processing that can result in remote code execution. This attack appears to be exploitable via thumbnail upload by an authenticated user and may require additional plugins in order to be exploited however this has not been confirmed at this time. This issue appears to have been partially, but not completely fixed in WordPress 4.9","date":"2018-09-06"}],"impact":{"cvss":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:L\/PR:L\/UI:N\/S:U\/C:H\/I:H\/A:H","av":"n","ac":"l","pr":"l","ui":"n","s":"u","c":"h","i":"h","a":"h","score":"8.8","severity":"h","exploitable":"2.8","impact":"5.9"},"cvss3":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:L\/PR:L\/UI:N\/S:U\/C:H\/I:H\/A:H","score":"8.8","severity":"high","av":"network","ac":"low","pr":"low","ui":"none","s":"unchanged","c":"high","i":"high","a":"high","exploitable":"2.8","impact":"5.9"},"cwe":[{"cwe":"CWE-20","name":"Improper Input Validation","description":"The product receives input or data, but it does\n        not validate or incorrectly validates that the input has the\n        properties that are required to process the data safely and\n        correctly."}]}},{"uuid":"bc19fe830c2aefc7a55481aaa2c71134da17f2365557da1c27824ed767799e74","name":"4.6.10","description":null,"source":[{"id":"6a560e89ec45e4b6d016ff6c6a82d899a707afb7","name":"WordPress Core < 4.9 - Insecure Deserialization","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-499-insecure-deserialization","description":"WordPress version <4.9 contains a CWE-20 Input Validation vulnerability in thumbnail processing that can result in remote code execution. This attack appears to be exploitable via thumbnail upload by an authenticated user and may require additional plugins in order to be exploited however this has not been confirmed at this time. This issue appears to have been partially, but not completely fixed in WordPress 4.9","date":"2018-08-16"}],"impact":[]},{"uuid":"e2e7dc16fffb0c282198949c986f1907e6af6473ee900cf99e01d45fe17c7832","name":"4.6.10","description":null,"source":[{"id":"CVE-2018-1000773","name":"CVE-2018-1000773","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2018-1000773","description":"[en] WordPress version 4.9.8 and earlier contains a CWE-20 Input Validation vulnerability in thumbnail processing that can result in remote code execution due to an incomplete fix for CVE-2017-1000600. This attack appears to be exploitable via thumbnail upload by an authenticated user and may require additional plugins in order to be exploited however this has not been confirmed at this time.","date":"2018-09-06"}],"impact":{"cvss":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:L\/PR:L\/UI:N\/S:U\/C:H\/I:H\/A:H","av":"n","ac":"l","pr":"l","ui":"n","s":"u","c":"h","i":"h","a":"h","score":"8.8","severity":"h","exploitable":"2.8","impact":"5.9"},"cvss3":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:L\/PR:L\/UI:N\/S:U\/C:H\/I:H\/A:H","score":"8.8","severity":"high","av":"network","ac":"low","pr":"low","ui":"none","s":"unchanged","c":"high","i":"high","a":"high","exploitable":"2.8","impact":"5.9"},"cwe":[{"cwe":"CWE-20","name":"Improper Input Validation","description":"The product receives input or data, but it does\n        not validate or incorrectly validates that the input has the\n        properties that are required to process the data safely and\n        correctly."}]}},{"uuid":"e2e7dc16fffb0c282198949c986f1907e6af6473ee900cf99e01d45fe17c7832","name":"4.6.10","description":null,"source":[{"id":"9373078848f68940809cb8c28b3cf7c55c10b65f","name":"WordPress Core < 5.0.1 - PHAR Unserialization","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-498-remote-code-execution","description":"WordPress Core versions before 5.0.1 contain a CWE-20 Input Validation vulnerability in thumbnail processing that can result in remote code execution due to an incomplete fix for CVE-2017-1000600. This attack appears to be exploitable via thumbnail upload by an authenticated user and may require additional plugins in order to be exploited however this has not been confirmed at this time.","date":"2018-09-06"}],"impact":[]},{"uuid":"48be99bc419d1fa27ef01606a19a28a1d5f402000efd8fb3da9930ff0474910d","name":"4.6.10","description":null,"source":[{"id":"13a9220ee8811d94195e25ea2956989bba2db545","name":"WordPress Core < 6.4.3 - Authenticated(Administrator+) PHP File Upload","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-497-php-file-upload","description":"In all current versions of WordPress Core before 6.4.3, plugins uploaded via the admin area are not verified as being ZIP files. This allows for PHP files to be uploaded. Once a PHP file is uploaded, the plugin extraction fails, but the PHP file remains in a predictable wp-content\/uploads location, allowing for an attacker to then execute the file. This represents a security risk in limited scenarios where an attacker (who does have the required capabilities for plugin uploads) cannot simply place arbitrary PHP code into a valid plugin ZIP file and upload that plugin, because a machine's wp-content\/plugins directory permissions were set up to block all new plugins. Please note that this requires administrator or super administrator permissions(on multisite installations) and only impacts heavily locked-down installations where even these users cannot install new plugins. CVE-2024-31210 may be a duplicate of this issue.","date":"2018-08-04"}],"impact":[]},{"uuid":"d9349cb67fb612b8e8a46bded77d15e64a8eb9ef51930ad1448e6ebdcfedba95","name":"4.6.10","description":null,"source":[{"id":"CVE-2018-12895","name":"CVE-2018-12895","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2018-12895","description":"[en] WordPress through 4.9.6 allows Author users to execute arbitrary code by leveraging directory traversal in the wp-admin\/post.php thumb parameter, which is passed to the PHP unlink function and can delete the wp-config.php file. This is related to missing filename validation in the wp-includes\/post.php wp_delete_attachment function. The attacker must have capabilities for files and posts that are normally available only to the Author, Editor, and Administrator roles. The attack methodology is to delete wp-config.php and then launch a new installation process to increase the attacker's privileges.","date":"2018-06-26"}],"impact":{"cvss":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:L\/UI:N\/S:U\/C:H\/I:H\/A:H","av":"n","ac":"l","pr":"l","ui":"n","s":"u","c":"h","i":"h","a":"h","score":"8.8","severity":"h","exploitable":"2.8","impact":"5.9"},"cvss3":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:L\/UI:N\/S:U\/C:H\/I:H\/A:H","score":"8.8","severity":"high","av":"network","ac":"low","pr":"low","ui":"none","s":"unchanged","c":"high","i":"high","a":"high","exploitable":"2.8","impact":"5.9"},"cwe":[{"cwe":"CWE-22","name":"Improper Limitation of a Pathname to a Restricted Directory ('Path Traversal')","description":"The product uses external input to construct a pathname that is intended to identify a file or directory that is located underneath a restricted parent directory, but the product does not properly neutralize special elements within the pathname that can cause the pathname to resolve to a location that is outside of the restricted directory."}]}},{"uuid":"d9349cb67fb612b8e8a46bded77d15e64a8eb9ef51930ad1448e6ebdcfedba95","name":"4.6.10","description":null,"source":[{"id":"7e8197d3a109b6971fc5ee73fc8ed89429df3607","name":"WordPress <=4.9.6 - Arbitrary Code Execution vulnerability","link":"https:\/\/patchstack.com\/database\/wordpress\/wordpress\/wordpress\/vulnerability\/wordpress-4-9-6-arbitrary-code-execution-vulnerability","description":"Arbitrary Code Execution vulnerability found by ripstech in WordPress (versions <=4.9.6).","date":"2018-06-27"}],"impact":[]},{"uuid":"d9349cb67fb612b8e8a46bded77d15e64a8eb9ef51930ad1448e6ebdcfedba95","name":"4.6.10","description":null,"source":[{"id":"ba19611b55e738ae109c43613b2b65e6eeb4ce9f","name":"WordPress Core < 4.9.7 - Authenticated Arbitrary File Deletion","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-497-authenticated-arbitrary-file-deletion","description":"WordPress through 4.9.6 allows Author users to execute arbitrary code by leveraging directory traversal in the wp-admin\/post.php thumb parameter, which is passed to the PHP unlink function and can delete the wp-config.php file. This is related to missing filename validation in the wp-includes\/post.php wp_delete_attachment function. The attacker must have capabilities for files and posts that are normally available only to the Author, Editor, and Administrator roles. The attack methodology is to delete wp-config.php and then launch a new installation process to increase the attacker's privileges.","date":"2018-07-05"}],"impact":[]},{"uuid":"6c867284b5efd407073c74eddcb50b0d2de284b2a26384f6aa3b502646e59d24","name":"4.6.10","description":null,"source":[{"id":"CVE-2018-10100","name":"CVE-2018-10100","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2018-10100","description":"[en] Before WordPress 4.9.5, the redirection URL for the login page was not validated or sanitized if forced to use HTTPS.","date":"2018-04-14"}],"impact":{"cvss":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:L\/PR:N\/UI:R\/S:C\/C:L\/I:L\/A:N","av":"n","ac":"l","pr":"n","ui":"r","s":"c","c":"l","i":"l","a":"n","score":"6.1","severity":"m","exploitable":"2.8","impact":"2.7"},"cvss3":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:L\/PR:N\/UI:R\/S:C\/C:L\/I:L\/A:N","score":"6.1","severity":"medium","av":"network","ac":"low","pr":"none","ui":"required","s":"changed","c":"low","i":"low","a":"none","exploitable":"2.8","impact":"2.7"},"cwe":[{"cwe":"CWE-601","name":"URL Redirection to Untrusted Site ('Open Redirect')","description":"The web application accepts a user-controlled input that specifies a link to an external site, and uses that link in a redirect."}]}},{"uuid":"6c867284b5efd407073c74eddcb50b0d2de284b2a26384f6aa3b502646e59d24","name":"4.6.10","description":null,"source":[{"id":"2bfdc53f5c533d51c69129d38befea4c03e99eb5","name":"WordPress Core < 4.9.5 - Open Redirect","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-495-open-redirect","description":"Before WordPress 4.9.5, the redirection URL for the login page was not validated or sanitized if forced to use HTTPS.","date":"2018-04-03"}],"impact":[]},{"uuid":"c937a309195afbf48b513a67e6de1ffd455291e8674fdad409b764e9173ff985","name":"4.6.10","description":null,"source":[{"id":"CVE-2018-10101","name":"CVE-2018-10101","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2018-10101","description":"[en] Before WordPress 4.9.5, the URL validator assumed URLs with the hostname localhost were on the same host as the WordPress server.","date":"2018-04-14"}],"impact":{"cvss":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:L\/PR:N\/UI:R\/S:C\/C:L\/I:L\/A:N","av":"n","ac":"l","pr":"n","ui":"r","s":"c","c":"l","i":"l","a":"n","score":"6.1","severity":"m","exploitable":"2.8","impact":"2.7"},"cvss3":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:L\/PR:N\/UI:R\/S:C\/C:L\/I:L\/A:N","score":"6.1","severity":"medium","av":"network","ac":"low","pr":"none","ui":"required","s":"changed","c":"low","i":"low","a":"none","exploitable":"2.8","impact":"2.7"},"cwe":[{"cwe":"CWE-601","name":"URL Redirection to Untrusted Site ('Open Redirect')","description":"The web application accepts a user-controlled input that specifies a link to an external site, and uses that link in a redirect."}]}},{"uuid":"c937a309195afbf48b513a67e6de1ffd455291e8674fdad409b764e9173ff985","name":"4.6.10","description":null,"source":[{"id":"b9cb8a05d3d9b4ddaa0e63effcd3a06b709c457d","name":"WordPress Core < 4.9.5 - Security Misconfiguration with URL Hostnames","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-495-security-misconfiguration-with-url-hostnames","description":"Before WordPress 4.9.5, the URL validator assumed URLs with the hostname localhost were on the same host as the WordPress server.","date":"2018-04-03"}],"impact":[]},{"uuid":"9a4b70ef760a665cd801d30041fad27fc0bc428da6ca87d6c439534635789d6c","name":"4.6.10","description":null,"source":[{"id":"CVE-2018-10102","name":"CVE-2018-10102","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2018-10102","description":"[en] Before WordPress 4.9.5, the version string was not escaped in the get_the_generator function, and could lead to XSS in a generator tag.","date":"2018-04-14"}],"impact":{"cvss":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:L\/PR:N\/UI:R\/S:C\/C:L\/I:L\/A:N","av":"n","ac":"l","pr":"n","ui":"r","s":"c","c":"l","i":"l","a":"n","score":"6.1","severity":"m","exploitable":"2.8","impact":"2.7"},"cvss3":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:L\/PR:N\/UI:R\/S:C\/C:L\/I:L\/A:N","score":"6.1","severity":"medium","av":"network","ac":"low","pr":"none","ui":"required","s":"changed","c":"low","i":"low","a":"none","exploitable":"2.8","impact":"2.7"},"cwe":[{"cwe":"CWE-79","name":"Improper Neutralization of Input During Web Page Generation ('Cross-site Scripting')","description":"The product does not neutralize or incorrectly neutralizes user-controllable input before it is placed in output that is used as a web page that is served to other users."}]}},{"uuid":"9a4b70ef760a665cd801d30041fad27fc0bc428da6ca87d6c439534635789d6c","name":"4.6.10","description":null,"source":[{"id":"1447e6f08c01d09b93209c299d2c62fc23094022","name":"WordPress Core < 4.9.5 - Authenticated Stored Cross-Site Scripting via Generator Tag","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-495-authenticated-stored-cross-site-scripting-via-generator-tag","description":"Before WordPress 4.9.5, the version string was not escaped in the get_the_generator function, and could lead to XSS in a generator tag.","date":"2018-04-03"}],"impact":[]},{"uuid":"2ac9a332152a5bdd97eb7ebf947290c45c87510d390ccbeebd08cea66bee1b80","name":"4.6.10","description":null,"source":[{"id":"CVE-2014-6412","name":"CVE-2014-6412","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2014-6412","description":"[en] WordPress before 4.4 makes it easier for remote attackers to predict password-recovery tokens via a brute-force approach.","date":"2018-04-12"}],"impact":{"cvss":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:H\/PR:N\/UI:N\/S:U\/C:H\/I:H\/A:H","av":"n","ac":"h","pr":"n","ui":"n","s":"u","c":"h","i":"h","a":"h","score":"8.1","severity":"h","exploitable":"2.2","impact":"5.9"},"cvss3":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:H\/PR:N\/UI:N\/S:U\/C:H\/I:H\/A:H","score":"8.1","severity":"high","av":"network","ac":"high","pr":"none","ui":"none","s":"unchanged","c":"high","i":"high","a":"high","exploitable":"2.2","impact":"5.9"},"cwe":[{"cwe":"CWE-640","name":"Weak Password Recovery Mechanism for Forgotten Password","description":"The product contains a mechanism for users to recover or change their passwords without knowing the original password, but the mechanism is weak."}]}},{"uuid":"2ac9a332152a5bdd97eb7ebf947290c45c87510d390ccbeebd08cea66bee1b80","name":"4.6.10","description":null,"source":[{"id":"737fc32f35e7cbd0e0a28dacbd793d26ec781901","name":"WordPress Core < 4.4 - Brute Force Password Recovery Tokens","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-44-brute-force-password-recovery-tokens","description":"WordPress before 4.4 makes it easier for remote attackers to predict password-recovery tokens via a brute-force approach.","date":"2015-02-12"}],"impact":[]},{"uuid":"115d3942eeb161fe77846f857e11d5ceddd3ff3011df8cbf66a40025403531eb","name":"4.6.10","description":null,"source":[{"id":"CVE-2018-6389","name":"CVE-2018-6389","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2018-6389","description":"[en] In WordPress through 4.9.2, unauthenticated attackers can cause a denial of service (resource consumption) by using the large list of registered .js files (from wp-includes\/script-loader.php) to construct a series of requests to load every file many times.","date":"2018-02-06"}],"impact":{"cvss":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:L\/PR:N\/UI:N\/S:U\/C:N\/I:N\/A:H","av":"n","ac":"l","pr":"n","ui":"n","s":"u","c":"n","i":"n","a":"h","score":"7.5","severity":"h","exploitable":"3.9","impact":"3.6"},"cvss3":{"version":"3.0","vector":"CVSS:3.0\/AV:N\/AC:L\/PR:N\/UI:N\/S:U\/C:N\/I:N\/A:H","score":"7.5","severity":"high","av":"network","ac":"low","pr":"none","ui":"none","s":"unchanged","c":"none","i":"none","a":"high","exploitable":"3.9","impact":"3.6"},"cwe":[{"cwe":"CWE-400","name":"Uncontrolled Resource Consumption","description":"The product does not properly control the allocation and maintenance of a limited resource."}]}},{"uuid":"115d3942eeb161fe77846f857e11d5ceddd3ff3011df8cbf66a40025403531eb","name":"4.6.10","description":null,"source":[{"id":"b138e3f1e70f6ff7eff0355f09e62542f3f37992","name":"WordPress <=4.9.2 - Application Denial of Service (DoS) vulnerability","link":"https:\/\/patchstack.com\/database\/wordpress\/wordpress\/wordpress\/vulnerability\/wordpress-4-9-2-application-denial-of-service-dos-vulnerability","description":"Application Denial of Service (DoS) vulnerability found in WordPress (versions <=4.9.2).","date":"2018-02-05"}],"impact":[]},{"uuid":"115d3942eeb161fe77846f857e11d5ceddd3ff3011df8cbf66a40025403531eb","name":"4.6.10","description":null,"source":[{"id":"0d78091dc09ec27bb3e98196267255b8684889c2","name":"WordPress Core < 5.0 - Denial of Service","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-492-denial-of-service","description":"In WordPress before 5.0, unauthenticated attackers can cause a denial of service (resource consumption) by using the large list of registered .js files (from wp-includes\/script-loader.php) to construct a series of requests to load every file many times. It looks like most of the slowness was due to forcing PHP to repeatedly compress the output scripts, which was addressed in 5.0.","date":"2018-02-05"}],"impact":[]},{"uuid":"96c902e2d11d4fe576c36b15ea3b9be96fea9e9a4fb43e4a39a1db1bd2d768ef","name":"4.6.10","description":null,"source":[{"id":"1978c6439d4ffbda7fe77056944c54b474d60ff0","name":"WordPress <= 5.9.1 - Stored Cross-Site Scripting (XSS) vulnerability","link":"https:\/\/patchstack.com\/database\/wordpress\/wordpress\/wordpress\/vulnerability\/wordpress-5-9-1-stored-cross-site-scripting-xss-vulnerability","description":"Stored Cross-Site Scripting (XSS) vulnerability discovered by Ben Bidner in WordPress (versions <= 5.9.1).","date":"2022-03-11"}],"impact":[]},{"uuid":"4954e8d460278b26c63b2bcc550e93b591bae9ef9b8c764bdcdd028c9dba682a","name":"4.6.10","description":null,"source":[{"id":"2bbe5c72a57fb5f3e94693e6244769337422525b","name":"WordPress core <= 5.8.1 - Expired DST Root CA X3 Certificate issue","link":"https:\/\/patchstack.com\/database\/wordpress\/wordpress\/wordpress\/vulnerability\/wordpress-core-5-8-1-expired-dst-root-ca-x3-certificate-issue","description":"Expired DST Root CA X3 Certificate issue discovered by Bradley Taylor in WordPress core (versions <= 5.8.1).","date":"2021-11-10"}],"impact":[]},{"uuid":"75f38fc6360daac2a09660b4a55f32a80c3215759ee6bfaa046193e74bc14770","name":"4.6.10","description":null,"source":[{"id":"490605922c1772788f6b0f30994c594b6d493e23","name":"WordPress core <= 5.8 - Command injection vulnerability in the Lodash library","link":"https:\/\/patchstack.com\/database\/wordpress\/wordpress\/wordpress\/vulnerability\/wordpress-core-5-8-command-injection-vulnerability-in-the-lodash-library","description":"Command injection vulnerability in the Lodash library in WordPress core (versions <= 5.8).\r\n\r\nVersion update list: 5.8 updated to 5.8.1, 5.7.2 updated to 5.7.3, 5.7.1 updated to 5.7.3, 5.7 updated to 5.7.3, 5.6.4 updated to 5.6.5, 5.6.3 updated to 5.6.5, 5.6.2 updated to 5.6.5, 5.6.1 updated to 5.6.5, 5.6 updated to 5.6.5, 5.5.5 updated to 5.5.6, 5.5.4 updated to 5.5.6, 5.5.3 updated to 5.5.6, 5.5.2 updated to 5.5.6, 5.5.1 updated to 5.5.6, 5.5 updated to 5.5.6, 5.4.6 updated to 5.4.7, 5.4.5 updated to 5.4.7, 5.4.4 updated to 5.4.7, 5.4.3 updated to 5.4.7, 5.4.2 updated to 5.4.7, 5.4.1 updated to 5.4.7, 5.4 updated to 5.4.7","date":"2021-09-09"}],"impact":[]},{"uuid":"f1080bd7003431309b0ec40a9486af7d3759bb84110a0a7d2a10a696749b2d7b","name":"4.6.10","description":null,"source":[{"id":"0fa3ffc1bfd20c1f310b5592a17d14135f7e8fd4","name":"WordPress <= 5.7.1 - Object injection in PHPMailer vulnerability","link":"https:\/\/patchstack.com\/database\/wordpress\/wordpress\/wordpress\/vulnerability\/wordpress-5-7-object-injection-in-phpmailer-vulnerability-cve-2020-36326","description":"Object injection in PHPMailer vulnerability discovered in WordPress (one security issue affecting WordPress versions between 3.7 and 5.7).","date":"2021-05-13"}],"impact":[]},{"uuid":"1b31c6978a69d9037c10703e022e756635e5c010956ccb9070713974fab1836f","name":"4.6.10","description":null,"source":[{"id":"CVE-2020-36326","name":"CVE-2020-36326","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2020-36326","description":"[en] PHPMailer 6.1.8 through 6.4.0 allows object injection through Phar Deserialization via addAttachment with a UNC pathname. NOTE: this is similar to CVE-2018-19296, but arose because 6.1.8 fixed a functionality problem in which UNC pathnames were always considered unreadable by PHPMailer, even in safe contexts. As an unintended side effect, this fix eliminated the code that blocked addAttachment exploitation.","date":"2021-04-28"}],"impact":{"cvss":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:N\/UI:N\/S:U\/C:H\/I:H\/A:H","av":"n","ac":"l","pr":"n","ui":"n","s":"u","c":"h","i":"h","a":"h","score":"9.8","severity":"c","exploitable":"3.9","impact":"5.9"},"cvss3":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:N\/UI:N\/S:U\/C:H\/I:H\/A:H","score":"9.8","severity":"critical","av":"network","ac":"low","pr":"none","ui":"none","s":"unchanged","c":"high","i":"high","a":"high","exploitable":"3.9","impact":"5.9"},"cwe":[{"cwe":"CWE-502","name":"Deserialization of Untrusted Data","description":"The product deserializes untrusted data without sufficiently ensuring that the resulting data will be valid."}]}},{"uuid":"76bc05f4729200d8122afe2915406b4f594a9e346e87d3993f8b8a00a2682317","name":"4.6.10","description":null,"source":[{"id":"ad1b26f36141d39ecc0ce9b69f34c9f0c0445b62","name":"WordPress core 4.7-5.7 - Sensitive Data Exposure vulnerability","link":"https:\/\/patchstack.com\/database\/wordpress\/wordpress\/wordpress\/vulnerability\/wordpress-core-4-7-5-7-sensitive-data-exposure-vulnerability","description":"Sensitive Data Exposure vulnerability discovered by Mikael Korpela in WordPress core (versions 4.7-5.7).","date":"2021-04-15"}],"impact":[]},{"uuid":"163e0c4b7cf8a7a5f79d2cddb4d3838839a77464850d6f2f855819e2d0d14cc2","name":"4.6.10","description":null,"source":[{"id":"878c3f63dab6c76f0344a4d3c247152861055548","name":"WordPress <= 5.5.1 - XML-RPC Privilege Escalation vulnerability","link":"https:\/\/patchstack.com\/database\/wordpress\/wordpress\/wordpress\/vulnerability\/wordpress-5-5-1-xml-rpc-privilege-escalation-vulnerability","description":"XML-RPC Privilege Escalation vulnerability found by Justin Tran in WordPress (versions <= 5.5.1).","date":"2020-10-29"}],"impact":[]},{"uuid":"3c96c2f04e514e1fb154d57adfd37ca382eefcbd348472489d2124d40ca575df","name":"4.6.10","description":null,"source":[{"id":"a6d6ba35b99dabc24f9c5b2a2d4cd835348393e1","name":"WordPress <= 5.3 - Stored Cross-Site Scripting (XSS) vulnerability","link":"https:\/\/patchstack.com\/database\/wordpress\/wordpress\/wordpress\/vulnerability\/wordpress-5-3-stored-cross-site-scripting-xss-vulnerability","description":"Stored Cross-Site Scripting (XSS) vulnerability found by Nguyen The Duc in WordPress (versions <= 5.3).","date":"2019-12-13"}],"impact":[]},{"uuid":"db835699ef30015206f4a4de93dde071271a15226fc9364b1823295080219b45","name":"4.6.10","description":null,"source":[{"id":"1fd8a6383ef380784a5ef2e3712844d5e5ddd7d0","name":"WordPress <= 5.2.3 -