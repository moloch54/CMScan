 CSRF.","date":"2019-10-14"}],"impact":[]},{"uuid":"7e1d81f2efee9253010e5af804508f73e190b0a142c9b00d1bcf9dba851eb11b","name":"4.6.10","description":null,"source":[{"id":"CVE-2019-17673","name":"CVE-2019-17673","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2019-17673","description":"[en] WordPress before 5.2.4 is vulnerable to poisoning of the cache of JSON GET requests because certain requests lack a Vary: Origin header.","date":"2019-10-17"}],"impact":{"cvss":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:N\/UI:N\/S:U\/C:N\/I:H\/A:N","av":"n","ac":"l","pr":"n","ui":"n","s":"u","c":"n","i":"h","a":"n","score":"7.5","severity":"h","exploitable":"3.9","impact":"3.6"},"cvss3":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:N\/UI:N\/S:U\/C:N\/I:H\/A:N","score":"7.5","severity":"high","av":"network","ac":"low","pr":"none","ui":"none","s":"unchanged","c":"none","i":"high","a":"none","exploitable":"3.9","impact":"3.6"}}},{"uuid":"7e1d81f2efee9253010e5af804508f73e190b0a142c9b00d1bcf9dba851eb11b","name":"4.6.10","description":null,"source":[{"id":"ae757362a32dad2f1216c16d73b7d2c43dfafe0b","name":"WordPress Core < 5.2.4 - Cache Poisoning","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-524-cache-poisoning","description":"WordPress before 5.2.4 is vulnerable to poisoning of the cache of JSON GET requests because certain requests lack a Vary: Origin header.","date":"2019-10-14"}],"impact":[]},{"uuid":"ae102aa775e78538c6ad9306e91f9461bfd7784fa9bf81b7eb73d77ead30065f","name":"4.6.10","description":null,"source":[{"id":"CVE-2019-17671","name":"CVE-2019-17671","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2019-17671","description":"[en] In WordPress before 5.2.4, unauthenticated viewing of certain content is possible because the static query property is mishandled.","date":"2019-10-17"}],"impact":{"cvss":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:N\/UI:N\/S:U\/C:L\/I:N\/A:N","av":"n","ac":"l","pr":"n","ui":"n"