erabilities\/wordpress-core\/wordpress-core-552-stored-cross-site-scripting-via-post-slugs","description":"WordPress before 5.5.2 allows stored XSS via post slugs.","date":"2020-10-29"}],"impact":[]},{"uuid":"bdb95912800e070c42edb8d835d5b12a933b5c2cd7ddc694c3aebcdd1f58bde5","name":"4.6.10","description":null,"source":[{"id":"CVE-2020-28039","name":"CVE-2020-28039","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2020-28039","description":"[en] is_protected_meta in wp-includes\/meta.php in WordPress before 5.5.2 allows arbitrary file deletion because it does not properly determine whether a meta key is considered protected.","date":"2020-10-31"}],"impact":{"cvss":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:N\/UI:N\/S:U\/C:N\/I:H\/A:H","av":"n","ac":"l","pr":"n","ui":"n","s":"u","c":"n","i":"h","a":"h","score":"9.1","severity":"c","exploitable":"3.9","impact":"5.2"},"cvss3":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:N\/UI:N\/S:U\/C:N\/I:H\/A:H","score":"9.1","severity":"critical","av":"network","ac":"low","pr":"none","ui":"none","s":"unchanged","c":"none","i":"high","a":"high","exploitable":"3.9","impact":"5.2"}}},{"uuid":"bdb95912800e070c42edb8d835d5b12a933b5c2cd7ddc694c3aebcdd1f58bde5","name":"4.6.10","description":null,"source":[{"id":"fa52d61186833df1f566d93a6282096f6a3e3a26","name":"WordPress <= 5.5.1 - Bypass Protected Meta That Could Lead To Arbitrary File Deletion vulnerability","link":"https:\/\/patchstack.com\/database\/wordpress\/wordpress\/wordpress\/vulnerability\/wordpress-core-5-5-1-bypass-protected-meta-that-could-lead-to-arbitrary-file-deletion-vulnerability","description":"Bypass Protected Meta That Could Lead To Arbitrary File Deletion vulnerability found by Slavco Mihajloski (mslavco) in WordPress (versions <= 5.5.1).","date":"2020-10-29"}],"impact":[]},{"uuid":"bdb95912800e070c42edb8d835d5b12a933b5c2cd7ddc694c3aebcdd1f58bde5","name":"4.6.10","description":null,"source":[{"id":"1d6995477ffea8edc5fd8f2370e6003d741644ed","name":"WordPress Core < 5.5.2 - Arbitrary File Deletion","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-552-arbitrary-file-deletion","description":"is_protected_meta in wp-includes\/meta.php in WordPress before 5.5.2 allows arbitrary file deletion because it does not properly determine whether a meta key is considered protected.","date":"2020-10-29"}],"impact":[]},{"uuid":"44f1d27d5cbd1bee0a993169f754b974749a77a5e235e1e053ae007ff5bfc5d6","name":"4.6.10","description":null,"source":[{"id":"CVE-2020-28040","name":"CVE-2020-28040","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2020-28040","description":"[en] WordPress before 5.5.2 allows CSRF attacks that change a theme's background image.","date":"2020-10-31"}],"impact":{"cvss":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:N\/UI:R\/S:U\/C:N\/I:L\/A:N","av":"n","ac":"l","pr":"n","ui":"r","s":"u","c":"n","i":"l","a":"n","score":"4.3","severity":"m","exploitable":"2.8","impact":"1.4"},"cvss3":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:N\/UI:R\/S:U\/C:N\/I:L\/A:N","score":"4.3","severity":"medium","av":"network","ac":"low","pr":"none","ui":"required","s":"unchanged","c":"none","i":"low","a":"none","exploitable":"2.8","impact":"1.4"},"cwe":[{"cwe":"CWE-352","name":"Cross-Site Request Forgery (CSRF)","description":"The web application does not, or cannot, sufficiently verify whether a request was intentionally provided by the user who sent the request, which could have originated from an unauthorized actor."}]}},{"uuid":"44f1d27d5cbd1bee0a993169f754b974749a77a5e235e1e053ae007ff5bfc5d6","name":"4.6.10","description":null,"source":[{"id":"2911f75ae4db7309f25b7936f8e00f36cc9e192d","name":"WordPress <= 5.5.1 - Cross-Site Request Forgery (CSRF) vulnerability","link":"https:\/\/patchstack.com\/database\/wordpress\/wordpress\/wordpress\/vulnerability\/wordpress-5-5-1-cross-site-request-forgery-csrf-vulnerability","description":"Cross-Site Request Forgery (CSRF) vulnerability found by Erwan LR in WordPress (versions <= 5.5.1).","date":"2020-10-29"}],"impact":[]},{"uuid":"44f1d27d5cbd1bee0a993169f754b974749a77a5e235e1e053ae007ff5bfc5d6","name":"4.6.10","description":null,"source":[{"id":"dddf375a0e572c48a6b9f9dcf6d0729299dc07b7","name":"WordPress Core < 5.5.2 - Cross-Site Request Forgery to Theme Image Change","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-552-cross-site-request-forgery-to-theme-image-change","description":"WordPress before 5.5.2 allows CSRF attacks that change a theme's background image.","date":"2020-10-29"}],"impact":[]},{"uuid":"fdb3d8eba96c381892dfdd330f813f2bb20ba3c33ebc4a915829ec1c593ac0fc","name":"4.6.10","description":null,"source":[{"id":"CVE-2020-4046","name":"CVE-2020-4046","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2020-4046","description":"[en] In affected versions of WordPress, users with low privileges (like contributors and authors) can use the embed block in a certain way to inject unfiltered HTML in the block editor. When affected posts are viewed by a higher privileged user, this could lead to script execution in the editor\/wp-admin. This has been patched in version 5.4.2, along with all the previously affected versions via a minor release (5.3.4, 5.2.7, 5.1.6, 5.0.10, 4.9.15, 4.8.14, 4.7.18, 4.6.19, 4.5.22, 4.4.23, 4.3.24, 4.2.28, 4.1.31, 4.0.31, 3.9.32, 3.8.34, 3.7.34).","date":"2020-06-12"}],"impact":{"cvss":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:L\/UI:R\/S:C\/C:L\/I:L\/A:N","av":"n","ac":"l","pr":"l","ui":"r","s":"c","c":"l","i":"l","a":"n","score":"5.4","severity":"m","exploitable":"2.3","impact":"2.7"},"cvss3":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:L\/UI:R\/S:C\/C:L\/I:L\/A:N","score":"5.4","severity":"medium","av":"network","ac":"low","pr":"low","ui":"required","s":"changed","c":"low","i":"low","a":"none","exploitable":"2.3","impact":"2.7"},"cwe":[{"cwe":"CWE-79","name":"Improper Neutralization of Input During Web Page Generation ('Cross-site Scripting')","description":"The product does not neutralize or incorrectly neutralizes user-controllable input before it is placed in output that is used as a web page that is served to other users."},{"cwe":"CWE-80","name":"Improper Neutralization of Script-Related HTML Tags in a Web Page (Basic XSS)","description":"The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special characters such as \"<\", \">\", and \"&\" that could be interpreted as web-scripting elements when they are sent to a downstream component that processes web pages."}]}},{"uuid":"fdb3d8eba96c381892dfdd330f813f2bb20ba3c33ebc4a915829ec1c593ac0fc","name":"4.6.10","description":null,"source":[{"id":"e28395c4cc8654d63b706476891e0888364234d6","name":"WordPress Core < 5.4.2 - Authenticated Stored Cross-Site Scripting","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-542-authenticated-stored-cross-site-scripting-2","description":"In affected versions of WordPress, users with low privileges (like contributors and authors) can use the embed block in a certain way to inject unfiltered HTML in the block editor. When affected posts are viewed by a higher privileged user, this could lead to script execution in the editor\/wp-admin. This has been patched in version 5.4.2, along with all the previously affected versions via a minor release (5.3.4, 5.2.7, 5.1.6, 5.0.10, 4.9.15, 4.8.14, 4.7.18, 4.6.19, 4.5.22, 4.4.23, 4.3.24, 4.2.28, 4.1.31, 4.0.31, 3.9.32, 3.8.34, 3.7.34).","date":"2020-06-10"}],"impact":[]},{"uuid":"ca75990727e9a1c65d4fa27da3248017c307690415368b96bdeea5d609f5c5d4","name":"4.6.10","description":null,"source":[{"id":"CVE-2020-4047","name":"CVE-2020-4047","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2020-4047","description":"[en] In affected versions of WordPress, authenticated users with upload permissions (like authors) are able to inject JavaScript into some media file attachment pages in a certain way. This can lead to script execution in the context of a higher privileged user when the file is viewed by them. This has been patched in version 5.4.2, along with all the previously affected versions via a minor release (5.3.4, 5.2.7, 5.1.6, 5.0.10, 4.9.15, 4.8.14, 4.7.18, 4.6.19, 4.5.22, 4.4.23, 4.3.24, 4.2.28, 4.1.31, 4.0.31, 3.9.32, 3.8.34, 3.7.34).","date":"2020-06-12"}],"impact":{"cvss":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:L\/UI:R\/S:C\/C:N\/I:H\/A:N","av":"n","ac":"l","pr":"l","ui":"r","s":"c","c":"n","i":"h","a":"n","score":"6.8","severity":"m","exploitable":"2.3","impact":"4.0"},"cvss3":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:L\/UI:R\/S:C\/C:N\/I:H\/A:N","score":"6.8","severity":"medium","av":"network","ac":"low","pr":"low","ui":"required","s":"changed","c":"none","i":"high","a":"none","exploitable":"2.3","impact":"4.0"},"cwe":[{"cwe":"CWE-80","name":"Improper Neutralization of Script-Related HTML Tags in a Web Page (Basic XSS)","description":"The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special characters such as \"<\", \">\", and \"&\" that could be interpreted as web-scripting elements when they are sent to a downstream component that processes web pages."}]}},{"uuid":"ca75990727e9a1c65d4fa27da3248017c307690415368b96bdeea5d609f5c5d4","name":"4.6.10","description":null,"source":[{"id":"7dd69725610653d47ca60d2977accfd27de911a9","name":"WordPress Core < 5.4.2 - Authenticated Stored Cross-Site Scripting","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-542-authenticated-stored-cross-site-scripting","description":"In affected versions of WordPress, authenticated users with upload permissions (like authors) are able to inject JavaScript into some media file attachment pages in a certain way. This can lead to script execution in the context of a higher privileged user when the file is viewed by them. This has been patched in version 5.4.2, along with all the previously affected versions via a minor release (5.3.4, 5.2.7, 5.1.6, 5.0.10, 4.9.15, 4.8.14, 4.7.18, 4.6.19, 4.5.22, 4.4.23, 4.3.24, 4.2.28, 4.1.31, 4.0.31, 3.9.32, 3.8.34, 3.7.34).","date":"2020-06-10"}],"impact":[]},{"uuid":"ca1bfa71e17f36daaf49808628a063cc8f54d130615e2700a2ae49e104a7f4ed","name":"4.6.10","description":null,"source":[{"id":"CVE-2020-4048","name":"CVE-2020-4048","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2020-4048","description":"[en] In affected versions of WordPress, due to an issue in wp_validate_redirect() and URL sanitization, an arbitrary external link can be crafted leading to unintended\/open redirect when clicked. This has been patched in version 5.4.2, along with all the previously affected versions via a minor release (5.3.4, 5.2.7, 5.1.6, 5.0.10, 4.9.15, 4.8.14, 4.7.18, 4.6.19, 4.5.22, 4.4.23, 4.3.24, 4.2.28, 4.1.31, 4.0.31, 3.9.32, 3.8.34, 3.7.34).","date":"2020-06-12"}],"impact":{"cvss":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:L\/UI:R\/S:U\/C:N\/I:H\/A:N","av":"n","ac":"l","pr":"l","ui":"r","s":"u","c":"n","i":"h","a":"n","score":"5.7","severity":"m","exploitable":"2.1","impact":"3.6"},"cvss3":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:L\/UI:R\/S:U\/C:N\/I:H\/A:N","score":"5.7","severity":"medium","av":"network","ac":"low","pr":"low","ui":"required","s":"unchanged","c":"none","i":"high","a":"none","exploitable":"2.1","impact":"3.6"},"cwe":[{"cwe":"CWE-601","name":"URL Redirection to Untrusted Site ('Open Redirect')","description":"The web application accepts a user-controlled input that specifies a link to an external site, and uses that link in a redirect."}]}},{"uuid":"ca1bfa71e17f36daaf49808628a063cc8f54d130615e2700a2ae49e104a7f4ed","name":"4.6.10","description":null,"source":[{"id":"3b75a1e30bf77d099006f103e711ed6b234ad900","name":"WordPress Core < 5.4.2 - Open Redirect","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-542-open-redirect","description":"In affected versions of WordPress, due to an issue in wp_validate_redirect() and URL sanitization, an arbitrary external link can be crafted leading to unintended\/open redirect when clicked. This has been patched in version 5.4.2, along with all the previously affected versions via a minor release (5.3.4, 5.2.7, 5.1.6, 5.0.10, 4.9.15, 4.8.14, 4.7.18, 4.6.19, 4.5.22, 4.4.23, 4.3.24, 4.2.28, 4.1.31, 4.0.31, 3.9.32, 3.8.34, 3.7.34).","date":"2020-06-10"}],"impact":[]},{"uuid":"9a51afb297bd0e8777323006bd4196a230fdae8f8d7721b264c4abda945c6c29","name":"4.6.10","description":null,"source":[{"id":"CVE-2020-4049","name":"CVE-2020-4049","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2020-4049","description":"[en] In affected versions of WordPress, when uploading themes, the name of the theme folder can be crafted in a way that could lead to JavaScript execution in \/wp-admin on the themes page. This does require an admin to upload the theme, and is low severity self-XSS. This has been patched in version 5.4.2, along with all the previously affected versions via a minor release (5.3.4, 5.2.7, 5.1.6, 5.0.10, 4.9.15, 4.8.14, 4.7.18, 4.6.19, 4.5.22, 4.4.23, 4.3.24, 4.2.28, 4.1.31, 4.0.31, 3.9.32, 3.8.34, 3.7.34).","date":"2020-06-12"}],"impact":{"cvss":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:H\/UI:R\/S:U\/C:N\/I:L\/A:N","av":"n","ac":"l","pr":"h","ui":"r","s":"u","c":"n","i":"l","a":"n","score":"2.4","severity":"l","exploitable":"0.9","impact":"1.4"},"cvss3":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:H\/UI:R\/S:U\/C:N\/I:L\/A:N","score":"2.4","severity":"low","av":"network","ac":"low","pr":"high","ui":"required","s":"unchanged","c":"none","i":"low","a":"none","exploitable":"0.9","impact":"1.4"},"cwe":[{"cwe":"CWE-79","name":"Improper Neutralization of Input During Web Page Generation ('Cross-site Scripting')","description":"The product does not neutralize or incorrectly neutralizes user-controllable input before it is placed in output that is used as a web page that is served to other users."},{"cwe":"CWE-80","name":"Improper Neutralization of Script-Related HTML Tags in a Web Page (Basic XSS)","description":"The product receives input from an upstream component, but it does not neutralize or incorrectly neutralizes special characters such as \"<\", \">\", and \"&\" that could be interpreted as web-scripting elements when they are sent to a downstream component that processes web pages."}]}},{"uuid":"9a51afb297bd0e8777323006bd4196a230fdae8f8d7721b264c4abda945c6c29","name":"4.6.10","description":null,"source":[{"id":"4e96821345e62ff463e82f865e94b9180f213bbe","name":"WordPress Core < 5.4.2 - Self-Cross Site Scripting via Theme Folder Name","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-542-self-cross-site-scripting-via-theme-folder-name","description":"In affected versions of WordPress, when uploading themes, the name of the theme folder can be crafted in a way that could lead to JavaScript execution in \/wp-admin on the themes page. This does require an admin to upload the theme, and is low severity self-XSS. This has been patched in version 5.4.2, along with all the previously affected versions via a minor release (5.3.4, 5.2.7, 5.1.6, 5.0.10, 4.9.15, 4.8.14, 4.7.18, 4.6.19, 4.5.22, 4.4.23, 4.3.24, 4.2.28, 4.1.31, 4.0.31, 3.9.32, 3.8.34, 3.7.34).","date":"2020-06-10"}],"impact":[]},{"uuid":"2480088dc247f2f570a57ff5b4b4cc50fbfe3ce2138c7dd936d733851b43a7f8","name":"4.6.10","description":null,"source":[{"id":"CVE-2020-4050","name":"CVE-2020-4050","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2020-4050","description":"[en] In affected versions of WordPress, misuse of the `set-screen-option` filter's return value allows arbitrary user meta fields to be saved. It does require an admin to install a plugin that would misuse the filter. Once installed, it can be leveraged by low privileged users. This has been patched in version 5.4.2, along with all the previously affected versions via a minor release (5.3.4, 5.2.7, 5.1.6, 5.0.10, 4.9.15, 4.8.14, 4.7.18, 4.6.19, 4.5.22, 4.4.23, 4.3.24, 4.2.28, 4.1.31, 4.0.31, 3.9.32, 3.8.34, 3.7.34).","date":"2020-06-12"}],"impact":{"cvss":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:H\/PR:L\/UI:N\/S:U\/C:N\/I:L\/A:N","av":"n","ac":"h","pr":"l","ui":"n","s":"u","c":"n","i":"l","a":"n","score":"3.1","severity":"l","exploitable":"1.6","impact":"1.4"},"cvss3":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:H\/PR:L\/UI:N\/S:U\/C:N\/I:L\/A:N","score":"3.1","severity":"low","av":"network","ac":"high","pr":"low","ui":"none","s":"unchanged","c":"none","i":"low","a":"none","exploitable":"1.6","impact":"1.4"},"cwe":[{"cwe":"CWE-288","name":"Authentication Bypass Using an Alternate Path or Channel","description":"The product requires authentication, but the product has an alternate path or channel that does not require authentication."}]}},{"uuid":"2480088dc247f2f570a57ff5b4b4cc50fbfe3ce2138c7dd936d733851b43a7f8","name":"4.6.10","description":null,"source":[{"id":"ed690f26d3085d8bafe1c8df00dd59c0f829a54e","name":"WordPress Core < 5.4.2 - Arbitrary User Meta Update","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-542-arbitrary-user-meta-update","description":"In affected versions of WordPress, misuse of the `set-screen-option` filter's return value allows arbitrary user meta fields to be saved. It does require an admin to install a plugin that would misuse the filter. Once installed, it can be leveraged by low privileged users. This has been patched in version 5.4.2, along with all the previously affected versions via a minor release (5.3.4, 5.2.7, 5.1.6, 5.0.10, 4.9.15, 4.8.14, 4.7.18, 4.6.19, 4.5.22, 4.4.23, 4.3.24, 4.2.28, 4.1.31, 4.0.31, 3.9.32, 3.8.34, 3.7.34).","date":"2020-06-10"}],"impact":[]},{"uuid":"b84a2a57c801a8b05083f5e2876bcee650f232d5b143264862385a58ce76496a","name":"4.6.10","description":null,"source":[{"id":"CVE-2020-11025","name":"CVE-2020-11025","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2020-11025","description":"[en] In affected versions of WordPress, a cross-site scripting (XSS) vulnerability in the navigation section of Customizer allows JavaScript code to be executed. Exploitation requires an authenticated user. This has been patched in version 5.4.1, along with all the previously affected versions via a minor release (5.3.3, 5.2.6, 5.1.5, 5.0.9, 4.9.14, 4.8.13, 4.7.17, 4.6.18, 4.5.21, 4.4.22, 4.3.23, 4.2.27, 4.1.30, 4.0.30, 3.9.31, 3.8.33, 3.7.33).","date":"2020-04-30"}],"impact":{"cvss":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:L\/UI:R\/S:C\/C:L\/I:L\/A:N","av":"n","ac":"l","pr":"l","ui":"r","s":"c","c":"l","i":"l","a":"n","score":"5.4","severity":"m","exploitable":"2.3","impact":"2.7"},"cvss3":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:L\/UI:R\/S:C\/C:L\/I:L\/A:N","score":"5.4","severity":"medium","av":"network","ac":"low","pr":"low","ui":"required","s":"changed","c":"low","i":"low","a":"none","exploitable":"2.3","impact":"2.7"},"cwe":[{"cwe":"CWE-79","name":"Improper Neutralization of Input During Web Page Generation ('Cross-site Scripting')","description":"The product does not neutralize or incorrectly neutralizes user-controllable input before it is placed in output that is used as a web page that is served to other users."}]}},{"uuid":"b84a2a57c801a8b05083f5e2876bcee650f232d5b143264862385a58ce76496a","name":"4.6.10","description":null,"source":[{"id":"48de8188be80d7724b7edf09372dfac0c82051ed","name":"WordPress Core < 5.4.1 - Authenticated Cross-Site Scripting via Customizer","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-541-authenticated-cross-site-scripting-via-customizer","description":"In affected versions of WordPress, a cross-site scripting (XSS) vulnerability in the navigation section of Customizer allows JavaScript code to be executed. Exploitation requires an authenticated user. This has been patched in version 5.4.1, along with all the previously affected versions via a minor release (5.3.3, 5.2.6, 5.1.5, 5.0.9, 4.9.14, 4.8.13, 4.7.17, 4.6.18, 4.5.21, 4.4.22, 4.3.23, 4.2.27, 4.1.30, 4.0.30, 3.9.31, 3.8.33, 3.7.33).","date":"2020-04-29"}],"impact":[]},{"uuid":"726ac3f8dd997a0bcc40ddd7b406473f9a95388ec0c061f5244914543f78985e","name":"4.6.10","description":null,"source":[{"id":"CVE-2020-11026","name":"CVE-2020-11026","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2020-11026","description":"[en] In affected versions of WordPress, files with a specially crafted name when uploaded to the Media section can lead to script execution upon accessing the file. This requires an authenticated user with privileges to upload files. This has been patched in version 5.4.1, along with all the previously affected versions via a minor release (5.3.3, 5.2.6, 5.1.5, 5.0.9, 4.9.14, 4.8.13, 4.7.17, 4.6.18, 4.5.21, 4.4.22, 4.3.23, 4.2.27, 4.1.30, 4.0.30, 3.9.31, 3.8.33, 3.7.33).","date":"2020-04-30"}],"impact":{"cvss":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:L\/UI:R\/S:C\/C:L\/I:L\/A:N","av":"n","ac":"l","pr":"l","ui":"r","s":"c","c":"l","i":"l","a":"n","score":"5.4","severity":"m","exploitable":"2.3","impact":"2.7"},"cvss3":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:L\/UI:R\/S:C\/C:L\/I:L\/A:N","score":"5.4","severity":"medium","av":"network","ac":"low","pr":"low","ui":"required","s":"changed","c":"low","i":"low","a":"none","exploitable":"2.3","impact":"2.7"},"cwe":[{"cwe":"CWE-79","name":"Improper Neutralization of Input During Web Page Generation ('Cross-site Scripting')","description":"The product does not neutralize or incorrectly neutralizes user-controllable input before it is placed in output that is used as a web page that is served to other users."},{"cwe":"CWE-707","name":"Improper Neutralization","description":"The product does not ensure or incorrectly ensures that structured messages or data are well-formed and that certain security properties are met before being read from an upstream component or sent to a downstream component."}]}},{"uuid":"726ac3f8dd997a0bcc40ddd7b406473f9a95388ec0c061f5244914543f78985e","name":"4.6.10","description":null,"source":[{"id":"68363655bca11e8c054e18522f5f95a6b3b539cc","name":"WordPress Core < 5.4.1 - Authenticated (Author+) Cross-Site Scripting via File Uploads","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-541-authenticated-author-cross-site-scripting-via-file-uploads","description":"In affected versions of WordPress, files with a specially crafted name when uploaded to the Media section can lead to script execution upon accessing the file. This requires an authenticated user with privileges to upload files. This has been patched in version 5.4.1, along with all the previously affected versions via a minor release (5.3.3, 5.2.6, 5.1.5, 5.0.9, 4.9.14, 4.8.13, 4.7.17, 4.6.18, 4.5.21, 4.4.22, 4.3.23, 4.2.27, 4.1.30, 4.0.30, 3.9.31, 3.8.33, 3.7.33).","date":"2020-04-29"}],"impact":[]},{"uuid":"10ccb9583d18dab6849f1846b1899291593efa30aa51df4554f285de6b4ef90d","name":"4.6.10","description":null,"source":[{"id":"CVE-2020-11027","name":"CVE-2020-11027","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2020-11027","description":"[en] In affected versions of WordPress, a password reset link emailed to a user does not expire upon changing the user password. Access would be needed to the email account of the user by a malicious party for successful execution. This has been patched in version 5.4.1, along with all the previously affected versions via a minor release (5.3.3, 5.2.6, 5.1.5, 5.0.9, 4.9.14, 4.8.13, 4.7.17, 4.6.18, 4.5.21, 4.4.22, 4.3.23, 4.2.27, 4.1.30, 4.0.30, 3.9.31, 3.8.33, 3.7.33).","date":"2020-04-30"}],"impact":{"cvss":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:L\/UI:N\/S:U\/C:H\/I:H\/A:N","av":"n","ac":"l","pr":"l","ui":"n","s":"u","c":"h","i":"h","a":"n","score":"8.1","severity":"h","exploitable":"2.8","impact":"5.2"},"cvss3":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:L\/UI:N\/S:U\/C:H\/I:H\/A:N","score":"8.1","severity":"high","av":"network","ac":"low","pr":"low","ui":"none","s":"unchanged","c":"high","i":"high","a":"none","exploitable":"2.8","impact":"5.2"},"cwe":[{"cwe":"CWE-640","name":"Weak Password Recovery Mechanism for Forgotten Password","description":"The product contains a mechanism for users to recover or change their passwords without knowing the original password, but the mechanism is weak."},{"cwe":"CWE-672","name":"Operation on a Resource after Expiration or Release","description":"The product uses, accesses, or otherwise operates on a resource after that resource has been expired, released, or revoked."}]}},{"uuid":"10ccb9583d18dab6849f1846b1899291593efa30aa51df4554f285de6b4ef90d","name":"4.6.10","description":null,"source":[{"id":"5bae8255e23e6727ba303bad09397e7bfba06b21","name":"WordPress Core < 5.4.1 - Password Reset Link Non-Expiration","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-541-password-reset-link-non-expiration","description":"In affected versions of WordPress, a password reset link emailed to a user does not expire upon changing the user password. Access would be needed to the email account of the user by a malicious party for successful execution. This has been patched in version 5.4.1, along with all the previously affected versions via a minor release (5.3.3, 5.2.6, 5.1.5, 5.0.9, 4.9.14, 4.8.13, 4.7.17, 4.6.18, 4.5.21, 4.4.22, 4.3.23, 4.2.27, 4.1.30, 4.0.30, 3.9.31, 3.8.33, 3.7.33).","date":"2020-04-29"}],"impact":[]},{"uuid":"eef02f9c6a5d7a070159b09e9f1e9b97347eebacd4071fa54200049a3456b22a","name":"4.6.10","description":null,"source":[{"id":"CVE-2020-11028","name":"CVE-2020-11028","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2020-11028","description":"[en] In affected versions of WordPress, some private posts, which were previously public, can result in unauthenticated disclosure under a specific set of conditions. This has been patched in version 5.4.1, along with all the previously affected versions via a minor release (5.3.3, 5.2.6, 5.1.5, 5.0.9, 4.9.14, 4.8.13, 4.7.17, 4.6.18, 4.5.21, 4.4.22, 4.3.23, 4.2.27, 4.1.30, 4.0.30, 3.9.31, 3.8.33, 3.7.33).","date":"2020-04-30"}],"impact":{"cvss":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:N\/UI:N\/S:U\/C:H\/I:N\/A:N","av":"n","ac":"l","pr":"n","ui":"n","s":"u","c":"h","i":"n","a":"n","score":"7.5","severity":"h","exploitable":"3.9","impact":"3.6"},"cvss3":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:N\/UI:N\/S:U\/C:H\/I:N\/A:N","score":"7.5","severity":"high","av":"network","ac":"low","pr":"none","ui":"none","s":"unchanged","c":"high","i":"none","a":"none","exploitable":"3.9","impact":"3.6"},"cwe":[{"cwe":"CWE-284","name":"Improper Access Control","description":"The product does not restrict or incorrectly restricts access to a resource from an unauthorized actor."},{"cwe":"CWE-306","name":"Missing Authentication for Critical Function","description":"The product does not perform any authentication for functionality that requires a provable user identity or consumes a significant amount of resources."}]}},{"uuid":"eef02f9c6a5d7a070159b09e9f1e9b97347eebacd4071fa54200049a3456b22a","name":"4.6.10","description":null,"source":[{"id":"303ae8b601aa1de24fd0273ef3b87c9ee7cc39f9","name":"WordPress Core < 5.4.1 - Private Post Disclosure","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-541-private-post-disclosure","description":"In affected versions of WordPress, some private posts, which were previously public, can result in unauthenticated disclosure under a specific set of conditions. This has been patched in version 5.4.1, along with all the previously affected versions via a minor release (5.3.3, 5.2.6, 5.1.5, 5.0.9, 4.9.14, 4.8.13, 4.7.17, 4.6.18, 4.5.21, 4.4.22, 4.3.23, 4.2.27, 4.1.30, 4.0.30, 3.9.31, 3.8.33, 3.7.33).","date":"2020-04-29"}],"impact":[]},{"uuid":"6639b208ac83af77b3c67bfee52824e1221c47a1446d27d1458522f47ef9c5ff","name":"4.6.10","description":null,"source":[{"id":"CVE-2020-11029","name":"CVE-2020-11029","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2020-11029","description":"[en] In affected versions of WordPress, a vulnerability in the stats() method of class-wp-object-cache.php can be exploited to execute cross-site scripting (XSS) attacks. This has been patched in version 5.4.1, along with all the previously affected versions via a minor release (5.3.3, 5.2.6, 5.1.5, 5.0.9, 4.9.14, 4.8.13, 4.7.17, 4.6.18, 4.5.21, 4.4.22, 4.3.23, 4.2.27, 4.1.30, 4.0.30, 3.9.31, 3.8.33, 3.7.33).","date":"2020-04-30"}],"impact":{"cvss":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:N\/UI:R\/S:C\/C:L\/I:L\/A:N","av":"n","ac":"l","pr":"n","ui":"r","s":"c","c":"l","i":"l","a":"n","score":"6.1","severity":"m","exploitable":"2.8","impact":"2.7"},"cvss3":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:N\/UI:R\/S:C\/C:L\/I:L\/A:N","score":"6.1","severity":"medium","av":"network","ac":"low","pr":"none","ui":"required","s":"changed","c":"low","i":"low","a":"none","exploitable":"2.8","impact":"2.7"},"cwe":[{"cwe":"CWE-79","name":"Improper Neutralization of Input During Web Page Generation ('Cross-site Scripting')","description":"The product does not neutralize or incorrectly neutralizes user-controllable input before it is placed in output that is used as a web page that is served to other users."}]}},{"uuid":"6639b208ac83af77b3c67bfee52824e1221c47a1446d27d1458522f47ef9c5ff","name":"4.6.10","description":null,"source":[{"id":"5c1afb2093dc29f37643d468c5bd67dacd935235","name":"WordPress Core < 5.4.1 - Reflected Cross Site Scripting","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-541-reflected-cross-site-scripting","description":"In affected versions of WordPress, a vulnerability in the stats() method of class-wp-object-cache.php can be exploited to execute cross-site scripting (XSS) attacks. This has been patched in version 5.4.1, along with all the previously affected versions via a minor release (5.3.3, 5.2.6, 5.1.5, 5.0.9, 4.9.14, 4.8.13, 4.7.17, 4.6.18, 4.5.21, 4.4.22, 4.3.23, 4.2.27, 4.1.30, 4.0.30, 3.9.31, 3.8.33, 3.7.33).","date":"2020-04-29"}],"impact":[]},{"uuid":"09ac08d5a46a14b4b6c423543771d94ade57a21b65e917bd3cebaca5ffcfef3d","name":"4.6.10","description":null,"source":[{"id":"CVE-2020-11030","name":"CVE-2020-11030","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2020-11030","description":"[en] In affected versions of WordPress, a special payload can be crafted that can lead to scripts getting executed within the search block of the block editor. This requires an authenticated user with the ability to add content. This has been patched in version 5.4.1, along with all the previously affected versions via a minor release (5.3.3, 5.2.6, 5.1.5, 5.0.9, 4.9.14, 4.8.13, 4.7.17, 4.6.18, 4.5.21, 4.4.22, 4.3.23, 4.2.27, 4.1.30, 4.0.30, 3.9.31, 3.8.33, 3.7.33).","date":"2020-04-30"}],"impact":{"cvss":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:L\/UI:R\/S:C\/C:L\/I:L\/A:N","av":"n","ac":"l","pr":"l","ui":"r","s":"c","c":"l","i":"l","a":"n","score":"5.4","severity":"m","exploitable":"2.3","impact":"2.7"},"cvss3":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:L\/UI:R\/S:C\/C:L\/I:L\/A:N","score":"5.4","severity":"medium","av":"network","ac":"low","pr":"low","ui":"required","s":"changed","c":"low","i":"low","a":"none","exploitable":"2.3","impact":"2.7"},"cwe":[{"cwe":"CWE-79","name":"Improper Neutralization of Input During Web Page Generation ('Cross-site Scripting')","description":"The product does not neutralize or incorrectly neutralizes user-controllable input before it is placed in output that is used as a web page that is served to other users."},{"cwe":"CWE-707","name":"Improper Neutralization","description":"The product does not ensure or incorrectly ensures that structured messages or data are well-formed and that certain security properties are met before being read from an upstream component or sent to a downstream component."}]}},{"uuid":"09ac08d5a46a14b4b6c423543771d94ade57a21b65e917bd3cebaca5ffcfef3d","name":"4.6.10","description":null,"source":[{"id":"6922d78603a681cc02900ed8dd6e0e9cbf599aa8","name":"WordPress Core < 5.4.1 - Cross-Site Scripting in the Block Editor","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-541-cross-site-scripting-in-the-block-editor","description":"In affected versions of WordPress, a special payload can be crafted that can lead to scripts getting executed within the search block of the block editor. This requires an authenticated user with the ability to add content. This has been patched in version 5.4.1, along with all the previously affected versions via a minor release (5.3.3, 5.2.6, 5.1.5, 5.0.9, 4.9.14, 4.8.13, 4.7.17, 4.6.18, 4.5.21, 4.4.22, 4.3.23, 4.2.27, 4.1.30, 4.0.30, 3.9.31, 3.8.33, 3.7.33).","date":"2020-04-29"}],"impact":[]},{"uuid":"7bbfe6a22d8ad2886453675bcd83d78c4f22344bcbd2e092c0306b4c12f771a7","name":"4.6.10","description":null,"source":[{"id":"CVE-2019-20041","name":"CVE-2019-20041","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2019-20041","description":"[en] wp_kses_bad_protocol in wp-includes\/kses.php in WordPress before 5.3.1 mishandles the HTML5 colon named entity, allowing attackers to bypass input sanitization, as demonstrated by the javascript&colon; substring.","date":"2019-12-27"}],"impact":{"cvss":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:N\/UI:N\/S:U\/C:H\/I:H\/A:H","av":"n","ac":"l","pr":"n","ui":"n","s":"u","c":"h","i":"h","a":"h","score":"9.8","severity":"c","exploitable":"3.9","impact":"5.9"},"cvss3":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:N\/UI:N\/S:U\/C:H\/I:H\/A:H","score":"9.8","severity":"critical","av":"network","ac":"low","pr":"none","ui":"none","s":"unchanged","c":"high","i":"high","a":"high","exploitable":"3.9","impact":"5.9"},"cwe":[{"cwe":"CWE-20","name":"Improper Input Validation","description":"The product receives input or data, but it does\n        not validate or incorrectly validates that the input has the\n        properties that are required to process the data safely and\n        correctly."}]}},{"uuid":"7bbfe6a22d8ad2886453675bcd83d78c4f22344bcbd2e092c0306b4c12f771a7","name":"4.6.10","description":null,"source":[{"id":"04cecb6a7cb71acefb1a505806f302403e4c21ae","name":"WordPress <= 5.3 - wp_kses_bad_protocol() Colon Bypass vulnerability","link":"https:\/\/patchstack.com\/database\/wordpress\/wordpress\/wordpress\/vulnerability\/wordpress-5-3-wp-kses-bad-protocol-colon-bypass-vulnerability","description":"wp_kses_bad_protocol() Colon Bypass vulnerability found by WordPress.org Security Team in WordPress (versions <= 5.3).","date":"2020-01-06"}],"impact":[]},{"uuid":"7bbfe6a22d8ad2886453675bcd83d78c4f22344bcbd2e092c0306b4c12f771a7","name":"4.6.10","description":null,"source":[{"id":"9fa940accd195c79bb6cee3a1798c0721d10a311","name":"WordPress Core < 5.3.1 - Authenticated Stored Cross-Site Scripting","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-531-authenticated-stored-cross-site-scripting-2","description":"wp_kses_bad_protocol in wp-includes\/kses.php in WordPress before 5.3.1 mishandles the HTML5 colon named entity, allowing attackers to bypass input sanitization, as demonstrated by the javascript&colon; substring.","date":"2019-12-13"}],"impact":[]},{"uuid":"6591857c40cb536ba8cd2eb628ea1f277e199f18f730614369d9b0c6400e0bc4","name":"4.6.10","description":null,"source":[{"id":"CVE-2019-20042","name":"CVE-2019-20042","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2019-20042","description":"[en] In wp-includes\/formatting.php in WordPress 3.7 to 5.3.0, the function wp_targeted_link_rel() can be used in a particular way to result in a stored cross-site scripting (XSS) vulnerability. This has been patched in WordPress 5.3.1, along with all the previous WordPress versions from 3.7 to 5.3 via a minor release.","date":"2019-12-27"}],"impact":{"cvss":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:N\/UI:R\/S:C\/C:L\/I:L\/A:N","av":"n","ac":"l","pr":"n","ui":"r","s":"c","c":"l","i":"l","a":"n","score":"6.1","severity":"m","exploitable":"2.8","impact":"2.7"},"cvss3":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:N\/UI:R\/S:C\/C:L\/I:L\/A:N","score":"6.1","severity":"medium","av":"network","ac":"low","pr":"none","ui":"required","s":"changed","c":"low","i":"low","a":"none","exploitable":"2.8","impact":"2.7"},"cwe":[{"cwe":"CWE-79","name":"Improper Neutralization of Input During Web Page Generation ('Cross-site Scripting')","description":"The product does not neutralize or incorrectly neutralizes user-controllable input before it is placed in output that is used as a web page that is served to other users."}]}},{"uuid":"6591857c40cb536ba8cd2eb628ea1f277e199f18f730614369d9b0c6400e0bc4","name":"4.6.10","description":null,"source":[{"id":"a470879953362c086bff1e60cad4694717b141f2","name":"WordPress Core < 5.3.1 - Authenticated Stored Cross-Site Scripting","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-531-authenticated-stored-cross-site-scripting-3","description":"In wp-includes\/formatting.php in WordPress 3.7 to 5.3.0, the function wp_targeted_link_rel() can be used in a particular way to result in a stored cross-site scripting (XSS) vulnerability. This has been patched in WordPress 5.3.1, along with all the previous WordPress versions from 3.7 to 5.3 via a minor release.","date":"2019-12-13"}],"impact":[]},{"uuid":"b23a728a11af6efe8a231a566dcaa49b515304776239dc2b94682108c5dcb363","name":"4.6.10","description":null,"source":[{"id":"CVE-2019-20043","name":"CVE-2019-20043","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2019-20043","description":"[en] In in wp-includes\/rest-api\/endpoints\/class-wp-rest-posts-controller.php in WordPress 3.7 to 5.3.0, authenticated users who do not have the rights to publish a post are able to mark posts as sticky or unsticky via the REST API. For example, the contributor role does not have such rights, but this allowed them to bypass that. This has been patched in WordPress 5.3.1, along with all the previous WordPress versions from 3.7 to 5.3 via a minor release.","date":"2019-12-27"}],"impact":{"cvss":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:L\/UI:N\/S:U\/C:N\/I:L\/A:N","av":"n","ac":"l","pr":"l","ui":"n","s":"u","c":"n","i":"l","a":"n","score":"4.3","severity":"m","exploitable":"2.8","impact":"1.4"},"cvss3":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:L\/UI:N\/S:U\/C:N\/I:L\/A:N","score":"4.3","severity":"medium","av":"network","ac":"low","pr":"low","ui":"none","s":"unchanged","c":"none","i":"low","a":"none","exploitable":"2.8","impact":"1.4"},"cwe":[{"cwe":"CWE-269","name":"Improper Privilege Management","description":"The product does not properly assign, modify, track, or check privileges for an actor, creating an unintended sphere of control for that actor."}]}},{"uuid":"b23a728a11af6efe8a231a566dcaa49b515304776239dc2b94682108c5dcb363","name":"4.6.10","description":null,"source":[{"id":"684d3380984ca8924f7e23fa23243e7bf8d36e9b","name":"WordPress Core < 5.3.1 - Authorization Bypass","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-531-authorization-bypass","description":"In in wp-includes\/rest-api\/endpoints\/class-wp-rest-posts-controller.php in WordPress 3.7 to 5.3.0, authenticated users who do not have the rights to publish a post are able to mark posts as sticky or unsticky via the REST API. For example, the contributor role does not have such rights, but this allowed them to bypass that. This has been patched in WordPress 5.3.1, along with all the previous WordPress versions from 3.7 to 5.3 via a minor release.","date":"2019-12-01"}],"impact":[]},{"uuid":"5fa61bb23191b66526b82dc8479bcaf3db35841ee5fc475e0f10dd22908b7fd1","name":"4.6.10","description":null,"source":[{"id":"CVE-2019-16780","name":"CVE-2019-16780","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2019-16780","description":"[en] WordPress users with lower privileges (like contributors) can inject JavaScript code in the block editor using a specific payload, which is executed within the dashboard. This can lead to XSS if an admin opens the post in the editor. Execution of this attack does require an authenticated user. This has been patched in WordPress 5.3.1, along with all the previous WordPress versions from 3.7 to 5.3 via a minor release. Automatic updates are enabled by default for minor releases and we strongly recommend that you keep them enabled.","date":"2019-12-26"}],"impact":{"cvss":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:L\/UI:R\/S:C\/C:L\/I:L\/A:N","av":"n","ac":"l","pr":"l","ui":"r","s":"c","c":"l","i":"l","a":"n","score":"5.4","severity":"m","exploitable":"2.3","impact":"2.7"},"cvss3":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:L\/UI:R\/S:C\/C:L\/I:L\/A:N","score":"5.4","severity":"medium","av":"network","ac":"low","pr":"low","ui":"required","s":"changed","c":"low","i":"low","a":"none","exploitable":"2.3","impact":"2.7"},"cwe":[{"cwe":"CWE-79","name":"Improper Neutralization of Input During Web Page Generation ('Cross-site Scripting')","description":"The product does not neutralize or incorrectly neutralizes user-controllable input before it is placed in output that is used as a web page that is served to other users."}]}},{"uuid":"5fa61bb23191b66526b82dc8479bcaf3db35841ee5fc475e0f10dd22908b7fd1","name":"4.6.10","description":null,"source":[{"id":"64eca727bfbdf99f4bfdab504a100a35104d7a53","name":"WordPress Core < 5.3.1 - Stored Cross-Site Scripting via Block Editor","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-531-stored-cross-site-scripting-via-block-editor","description":"WordPress users with lower privileges (like contributors) can inject JavaScript code in the block editor using a specific payload, which is executed within the dashboard. This can lead to XSS if an admin opens the post in the editor. Execution of this attack does require an authenticated user. This has been patched in WordPress 5.3.1, along with all the previous WordPress versions from 3.7 to 5.3 via a minor release. Automatic updates are enabled by default for minor releases and we strongly recommend that you keep them enabled.","date":"2019-12-13"}],"impact":[]},{"uuid":"4acde568f02ecbb0ce2f28b656acfcd97bf5f768bf4a75ec5d51ae4a91ab1f49","name":"4.6.10","description":null,"source":[{"id":"CVE-2019-16781","name":"CVE-2019-16781","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2019-16781","description":"[en] In WordPress before 5.3.1, authenticated users with lower privileges (like contributors) can inject JavaScript code in the block editor, which is executed within the dashboard. It can lead to an admin opening the affected post in the editor leading to XSS.","date":"2019-12-26"}],"impact":{"cvss":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:L\/UI:R\/S:C\/C:L\/I:L\/A:N","av":"n","ac":"l","pr":"l","ui":"r","s":"c","c":"l","i":"l","a":"n","score":"5.4","severity":"m","exploitable":"2.3","impact":"2.7"},"cvss3":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:L\/UI:R\/S:C\/C:L\/I:L\/A:N","score":"5.4","severity":"medium","av":"network","ac":"low","pr":"low","ui":"required","s":"changed","c":"low","i":"low","a":"none","exploitable":"2.3","impact":"2.7"},"cwe":[{"cwe":"CWE-79","name":"Improper Neutralization of Input During Web Page Generation ('Cross-site Scripting')","description":"The product does not neutralize or incorrectly neutralizes user-controllable input before it is placed in output that is used as a web page that is served to other users."}]}},{"uuid":"4acde568f02ecbb0ce2f28b656acfcd97bf5f768bf4a75ec5d51ae4a91ab1f49","name":"4.6.10","description":null,"source":[{"id":"9ce65024a60778f93c3d2ccc98c00160c31bf389","name":"WordPress Core < 5.3.1 - Authenticated Stored Cross-Site Scripting","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-531-authenticated-stored-cross-site-scripting","description":"In WordPress before 5.3.1, authenticated users with lower privileges (like contributors) can inject JavaScript code in the block editor, which is executed within the dashboard. It can lead to an admin opening the affected post in the editor leading to XSS.","date":"2019-12-13"}],"impact":[]},{"uuid":"17dbf76d46af0c75ae4d073784cccc8d5651124c1a44b12edf4ac6982d702483","name":"4.6.10","description":null,"source":[{"id":"CVE-2019-17669","name":"CVE-2019-17669","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2019-17669","description":"[en] WordPress before 5.2.4 has a Server Side Request Forgery (SSRF) vulnerability because URL validation does not consider the interpretation of a name as a series of hex characters.","date":"2019-10-17"}],"impact":{"cvss":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:N\/UI:N\/S:U\/C:H\/I:H\/A:H","av":"n","ac":"l","pr":"n","ui":"n","s":"u","c":"h","i":"h","a":"h","score":"9.8","severity":"c","exploitable":"3.9","impact":"5.9"},"cvss3":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:N\/UI:N\/S:U\/C:H\/I:H\/A:H","score":"9.8","severity":"critical","av":"network","ac":"low","pr":"none","ui":"none","s":"unchanged","c":"high","i":"high","a":"high","exploitable":"3.9","impact":"5.9"},"cwe":[{"cwe":"CWE-918","name":"Server-Side Request Forgery (SSRF)","description":"The web server receives a URL or similar request from an upstream component and retrieves the contents of this URL, but it does not sufficiently ensure that the request is being sent to the expected destination."}]}},{"uuid":"17dbf76d46af0c75ae4d073784cccc8d5651124c1a44b12edf4ac6982d702483","name":"4.6.10","description":null,"source":[{"id":"407f65d7679a1cfa33850996af7010b8f2763d13","name":"WordPress Core < 5.2.4 - Server Side Request Forgery","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-524-server-side-request-forgery","description":"WordPress before 5.2.4 has a Server Side Request Forgery (SSRF) vulnerability because URL validation does not consider the interpretation of a name as a series of hex characters.","date":"2019-10-14"}],"impact":[]},{"uuid":"93a31e56dc4dbe9ec60b4f7a19d1c5d851e16bd0876bd1513d884c2cadc718a2","name":"4.6.10","description":null,"source":[{"id":"CVE-2019-17670","name":"CVE-2019-17670","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2019-17670","description":"[en] WordPress before 5.2.4 has a Server Side Request Forgery (SSRF) vulnerability because Windows paths are mishandled during certain validation of relative URLs.","date":"2019-10-17"}],"impact":{"cvss":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:N\/UI:N\/S:U\/C:H\/I:H\/A:H","av":"n","ac":"l","pr":"n","ui":"n","s":"u","c":"h","i":"h","a":"h","score":"9.8","severity":"c","exploitable":"3.9","impact":"5.9"},"cvss3":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:N\/UI:N\/S:U\/C:H\/I:H\/A:H","score":"9.8","severity":"critical","av":"network","ac":"low","pr":"none","ui":"none","s":"unchanged","c":"high","i":"high","a":"high","exploitable":"3.9","impact":"5.9"},"cwe":[{"cwe":"CWE-918","name":"Server-Side Request Forgery (SSRF)","description":"The web server receives a URL or similar request from an upstream component and retrieves the contents of this URL, but it does not sufficiently ensure that the request is being sent to the expected destination."}]}},{"uuid":"93a31e56dc4dbe9ec60b4f7a19d1c5d851e16bd0876bd1513d884c2cadc718a2","name":"4.6.10","description":null,"source":[{"id":"8b8e081743ba5c5cd4ba00bd3e429cf674797560","name":"WordPress Core < 5.2.4 - Server Side Request Forgery #2","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-524-server-side-request-forgery-2","description":"WordPress before 5.2.4 has a Server Side Request Forgery (SSRF) vulnerability because Windows paths are mishandled during certain validation of relative URLs.","date":"2019-10-14"}],"impact":[]},{"uuid":"96991891e2f2505616abd2d229717eac4ce54caa1c29d09fa4985894f904934d","name":"4.6.10","description":null,"source":[{"id":"CVE-2019-17674","name":"CVE-2019-17674","link":"https:\/\/www.cve.org\/CVERecord?id=CVE-2019-17674","description":"[en] WordPress before 5.2.4 is vulnerable to stored XSS (cross-site scripting) via the Customizer.","date":"2019-10-17"}],"impact":{"cvss":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:L\/UI:R\/S:C\/C:L\/I:L\/A:N","av":"n","ac":"l","pr":"l","ui":"r","s":"c","c":"l","i":"l","a":"n","score":"5.4","severity":"m","exploitable":"2.3","impact":"2.7"},"cvss3":{"version":"3.1","vector":"CVSS:3.1\/AV:N\/AC:L\/PR:L\/UI:R\/S:C\/C:L\/I:L\/A:N","score":"5.4","severity":"medium","av":"network","ac":"low","pr":"low","ui":"required","s":"changed","c":"low","i":"low","a":"none","exploitable":"2.3","impact":"2.7"},"cwe":[{"cwe":"CWE-79","name":"Improper Neutralization of Input During Web Page Generation ('Cross-site Scripting')","description":"The product does not neutralize or incorrectly neutralizes user-controllable input before it is placed in output that is used as a web page that is served to other users."}]}},{"uuid":"96991891e2f2505616abd2d229717eac4ce54caa1c29d09fa4985894f904934d","name":"4.6.10","description":null,"source":[{"id":"963d67b28f2f2f5d621d3e4a03c579ccf72451b7","name":"WordPress Core < 5.2.4 - Authenticated Stored Cross-Site Scripting via Customizer","link":"https:\/\/www.wordfence.com\/threat-intel\/vulnerabilities\/wordpress-core\/wordpress-core-524-authenticated-stored-cross-site-scripting-via-customizer","description":"WordPress before 5.2.4 is vulnerable to stored XSS (cross-site scripting) via the Customizer.","date":"2019-1